# scripts/.env — Local secrets for SEO automation scripts
# Copy this file to scripts/.env and fill in your actual API key
# File is gitignored — NEVER commit real keys to repo

# LLM API (OpenAI-compatible). User provided key:
# - Base URL: try openrouter.ai/api/v1 first (most common free model aggregator)
# - Model: deepseek/deepseek-chat:free or tencent/hunyuan-pro or similar free model
# - To rotate: generate new key di provider dashboard
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat:free
LLM_API_KEY=YOUR_KEY_HERE
LLM_PROVIDER=openrouter

# Optional: fallback providers (if primary fails 429)
LLM_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
LLM_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# GSC service account (Day 6+)
GSC_CREDENTIALS_BASE64=

# Telegram bot (Day 14)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
