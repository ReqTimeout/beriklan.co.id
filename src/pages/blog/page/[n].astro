---
// Paginated blog archive — /blog/page/2/, /blog/page/3/, ...
// SEO: each page has a self-canonical + rel=prev/rel=next chain so paginated
// archives don't create duplicate-content/cannibalization issues.
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.svelte';
import StickyCTA from '../../../components/StickyCTA.svelte';
import Footer from '../../../components/Footer.svelte';
import { Calendar, Clock, ArrowRight, ArrowLeft } from 'lucide-svelte';
import { getFeaturedImage } from '../../../utils/featured_image.js';
import posts from '../../../data/posts.json';

const PAGE_SIZE = 24;
const total = posts.length;
const totalPages = Math.ceil(total / PAGE_SIZE);

export function getStaticPaths() {
    const PS = 24;
    const tp = Math.ceil(posts.length / PS);
    const paths = [];
    for (let n = 2; n <= tp; n++) {
        paths.push({ params: { n: String(n) } });
    }
    return paths;
}

const { n: nStr } = Astro.params;
const pageNum = parseInt(nStr, 10);
const start = (pageNum - 1) * PAGE_SIZE;
const pagePosts = posts.slice(start, start + PAGE_SIZE);

const base = 'https://beriklan.co.id';
const selfUrl = `${base}/blog/page/${pageNum}/`;
const prevUrl = pageNum === 2 ? `${base}/blog/` : `${base}/blog/page/${pageNum - 1}/`;
const nextUrl = pageNum < totalPages ? `${base}/blog/page/${pageNum + 1}/` : null;

function getImage(post) {
    return getFeaturedImage(post);
}
---

<Layout title={`Blog Digital Marketing — Halaman ${pageNum} | Beriklan`} description={`Tips, strategi, dan studi kasus digital marketing dari tim Beriklan. Halaman ${pageNum} dari ${totalPages}.`} canonical={selfUrl} prevUrl={prevUrl} nextUrl={nextUrl}>

    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <!-- ====================== HERO ====================== -->
    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-20 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="container mx-auto px-6 text-center max-w-3xl relative z-10">
            <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm mb-6">
                Blog · Halaman {pageNum} / {totalPages}
            </div>
            <h1 class="font-display font-extrabold text-4xl md:text-5xl lg:text-6xl text-ink leading-[1.05] tracking-tight mb-6">
                Artikel Digital Marketing<br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent">Halaman {pageNum}.</span>
            </h1>
            <p class="text-base md:text-lg text-muted leading-relaxed">
                Tips, panduan, dan studi kasus dari tim Beriklan — berdasarkan data dan pengalaman mengelola campaign lintas industri sejak 2016.
            </p>
        </div>
    </header>

    <!-- ====================== POSTS GRID ====================== -->
    <section class="py-16 md:py-20 bg-white">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal-stagger">
                {pagePosts.map((post, i) => (
                    <a href={`/blog/${post.slug}`} class="grid-card group" style={`animation-delay:${i * 40}ms;`}>
                        <div class="grid-thumb">
                            <img src={getImage(post)} alt={post.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                        </div>
                        <div class="p-5">
                            <span class="inline-block px-2 py-0.5 bg-soft text-ink text-[10px] font-bold uppercase tracking-wider rounded mb-3">{post.category}</span>
                            <h3 class="font-display font-bold text-base text-ink leading-tight mb-2 group-hover:text-accent transition-colors line-clamp-2">{post.title}</h3>
                            <p class="text-xs text-muted leading-relaxed line-clamp-3">{post.excerpt}</p>
                            <div class="flex items-center gap-3 mt-3 text-[10px] text-muted">
                                <span class="flex items-center gap-1"><Calendar class="w-3 h-3" /> {post.date}</span>
                                <span class="flex items-center gap-1"><Clock class="w-3 h-3" /> {post.readTime}</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            <!-- ====================== PAGINATION ====================== -->
            <nav class="flex items-center justify-center gap-2 mt-12 flex-wrap" aria-label="Pagination blog">
                <a href={prevUrl} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-bold border border-gray-200 bg-white hover:border-ink transition-all">
                    <ArrowLeft class="w-3.5 h-3.5" /> Sebelumnya
                </a>
                <span class="px-4 py-2 text-xs font-bold text-ink">
                    Halaman {pageNum} dari {totalPages}
                </span>
                {nextUrl ? (
                    <a href={nextUrl} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-bold bg-ink text-white hover:bg-primary-2 transition-all">
                        Berikutnya <ArrowRight class="w-3.5 h-3.5" />
                    </a>
                ) : (
                    <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-bold border border-gray-100 text-muted cursor-default">
                        Berikutnya <ArrowRight class="w-3.5 h-3.5" />
                    </span>
                )}
            </nav>

            <div class="text-center mt-6">
                <a href="/blog/" class="text-sm font-bold text-accent hover:underline">← Kembali ke halaman utama blog</a>
            </div>
        </div>
    </section>

    <Footer />
</Layout>

<style>
    .hero-grid {
        background-image: linear-gradient(rgba(15,30,61,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(15,30,61,.04) 1px, transparent 1px);
        background-size: 48px 48px;
    }
    .grid-card {
        background: white;
        border: 1px solid #f1f3f8;
        border-radius: 1.25rem;
        overflow: hidden;
        transition: all 0.3s ease;
        display: block;
    }
    .grid-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px -8px rgba(15,30,61,0.15);
        border-color: #f59e0b;
    }
    .grid-thumb {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
    }
    .grid-thumb img {
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .grid-card:hover .grid-thumb img {
        transform: scale(1.04);
    }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
