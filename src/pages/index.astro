---
import Layout from '../layouts/Layout.astro';

import Navbar from '../components/Navbar.svelte';
import StickyCTA from '../components/StickyCTA.svelte';
import HeroVisual from '../components/HeroVisual.svelte';
import PainPoints from '../components/PainPoints.svelte';
import AuditTool from '../components/AuditTool.svelte';
import Method from '../components/Method.svelte';
import Services from '../components/Services.svelte';
import Testimonials from '../components/Testimonials.svelte';
import Faq from '../components/Faq.svelte';
import Footer from '../components/Footer.svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20ingin%20audit%20campaign%20iklan%20saya";
---

<Layout>
    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <!-- ====================== HERO ====================== -->
    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-28 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="abs-blob abs-blob-1"></div>
        <div class="abs-blob abs-blob-2"></div>

        <!-- Decorative dotted line -->
        <svg class="absolute left-1/2 -translate-x-1/2 top-32 w-40 h-12 opacity-30 hidden lg:block" viewBox="0 0 160 40" aria-hidden="true">
            <path d="M5,20 Q40,5 80,20 T155,20" stroke="#0f1e3d" stroke-width="1.5" fill="none" stroke-dasharray="3 5"/>
        </svg>

        <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
            <div class="space-y-7 text-center lg:text-left">
                <!-- Eyebrow -->
                <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
                    </span>
                    <span class="opacity-0 anim-fade-in">Performance Agency · Sejak 2016</span>
                </div>

                <h1 class="hero-h1 font-display font-extrabold text-4xl md:text-5xl lg:text-[2.75rem] xl:text-6xl text-ink leading-[1.05] tracking-tight">
                    <span class="anim-fade-up">Iklan jalan,</span><br/>
                    <span class="anim-fade-up" style="animation-delay: 80ms;">tetapi <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent">closing sepi.</span></span><br/>
                    <span class="anim-fade-up" style="animation-delay: 160ms;">Kami tahu <span class="underline decoration-accent decoration-4 underline-offset-4">apa yang harus</span> diperbaiki.</span>
                </h1>

                <p class="hero-sub text-base md:text-lg text-muted leading-relaxed max-w-xl mx-auto lg:mx-0 anim-fade-up" style="animation-delay: 240ms;">
                    Dari ratusan campaign yang kami audit di berbagai industri, ada satu pola yang berulang: <strong class="text-ink">budget keluar</strong>, tapi hasilnya tak sebanding. Penyebabnya biasanya tiga — <strong class="text-ink">targeting melebar</strong>, <strong class="text-ink">iklan tak nyambung dengan audiens</strong>, atau <strong class="text-ink">landing page yang tak menutup</strong>. Kami diagnosa dulu — baru susun strategi yang terukur untuk bisnis Anda.
                </p>

                <div class="hero-ctas flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2 anim-fade-up" style="animation-delay: 320ms;">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-ink text-white px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine">
                        <span class="relative z-10 flex items-center gap-2">
                            Minta Audit Gratis 15 Menit
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 group-hover:rotate-12 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                    </a>
                    <a href="#layanan" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full font-bold text-ink border border-gray-200 bg-white hover:border-ink hover:-translate-y-0.5 transition-all">
                        Lihat Layanan &amp; Harga
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </a>
                </div>

                <div class="hero-trust pt-5 border-t border-gray-200/60 flex flex-wrap items-center justify-center lg:justify-start gap-x-3 gap-y-2 text-xs md:text-sm reveal" style="transition-delay: 200ms;">
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted"><strong class="text-ink">9 tahun</strong> mengelola iklan berbagai industri</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Tim bersertifikasi <strong class="text-ink">Meta &amp; Google</strong></span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Laporan <strong class="text-ink">bahasa manusia</strong>, bukan jargon</span></div>
                </div>
            </div>

            <div class="relative flex justify-center lg:justify-end">
                <HeroVisual client:only="svelte" />
            </div>
        </div>

        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-1 text-muted text-[10px] uppercase tracking-widest font-bold scroll-cue">
            Scroll
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </div>
    </header>

    <!-- ====================== TRUST BAR (industries) ====================== -->
    <section class="py-7 bg-ink border-y border-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
                <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.18em] text-white/40">Dipercaya bisnis dari berbagai industri</p>
                <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-white/70 text-sm font-semibold trust-word">
                    <span>F&amp;B</span><span class="text-white/30">·</span>
                    <span>Fashion</span><span class="text-white/30">·</span>
                    <span>Skincare</span><span class="text-white/30">·</span>
                    <span>Edutech</span><span class="text-white/30">·</span>
                    <span>SaaS B2B</span><span class="text-white/30">·</span>
                    <span>Klinik</span><span class="text-white/30">·</span>
                    <span>Properti</span><span class="text-white/30">·</span>
                    <span>Tour &amp; Travel</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== PAIN POINTS ====================== -->
    <PainPoints client:only="svelte" />

    <!-- ====================== AUDIT TOOL ====================== -->
    <AuditTool client:only="svelte" />

    <!-- ====================== METHOD ====================== -->
    <Method client:only="svelte" />

    <!-- ====================== SERVICES ====================== -->
    <Services client:only="svelte" />

    <!-- ====================== STATS / TRUST ====================== -->
    <section class="py-20 md:py-28 bg-ink text-white relative overflow-hidden">
        <div class="abs-radaial-1"></div>
        <!-- floating dots -->
        <div class="stat-orb stat-orb-1"></div>
        <div class="stat-orb stat-orb-2"></div>

        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Cara Kami Bekerja
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-white leading-[1.1] tracking-tight mt-3">
                    Tiga pilar kerja<br/>
                    <span class="text-accent">yang membedakan kami.</span>
                </h2>
                <p class="text-white/60 mt-4 text-base max-w-xl mx-auto">
                    Bukan sekadar janji di atas kertas. Setiap pilar bisa Anda cek sendiri — dari laporan mingguan, akses penuh ke dashboard Meta/Google, hingga rincian biaya yang jelas sejak hari pertama.
                </p>
            </div>

            <div class="grid md:grid-cols-4 gap-4 max-w-5xl mx-auto reveal-stagger">
                <div class="stat-card">
                    <div class="stat-num">9 th</div>
                    <div class="stat-label">Pengalaman tim</div>
                    <div class="stat-bar"><span style="width: 90%"></span></div>
                    <p class="stat-foot">performance marketing sejak 2016</p>
                </div>
                <div class="stat-card" style="animation-delay: 80ms;">
                    <div class="stat-num">7</div>
                    <div class="stat-label">Channel terkelola</div>
                    <div class="stat-bar"><span style="width: 100%"></span></div>
                    <p class="stat-foot">Meta, Google, TikTok, YouTube</p>
                </div>
                <div class="stat-card" style="animation-delay: 160ms;">
                    <div class="stat-num">12+</div>
                    <div class="stat-label">Sektor industri</div>
                    <div class="stat-bar"><span style="width: 76%"></span></div>
                    <p class="stat-foot">F&B, klinik, SaaS, retail</p>
                </div>
                <div class="stat-card" style="animation-delay: 240ms;">
                    <div class="stat-num">100%</div>
                    <div class="stat-label">Laporan transparan</div>
                    <div class="stat-bar"><span style="width: 100%"></span></div>
                    <p class="stat-foot">bukan hanya angka tanpa penjelasan</p>
                </div>
            </div>

            <div class="mt-14 grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="trust-item" style="animation-delay: 280ms;">
                    <div class="trust-icon">🔒</div>
                    <h3 class="trust-title">Akses penuh ke akun Anda</h3>
                    <p class="trust-desc">Seluruh akun Meta, Google, dan TikTok tetap di bawah kendali Anda. Bila sewaktu-waktu dibutuhkan, seluruh data historis dan konfigurasi berpindah tanpa hambatan.</p>
                </div>
                <div class="trust-item" style="animation-delay: 360ms;">
                    <div class="trust-icon">📊</div>
                    <h3 class="trust-title">Laporan setiap Senin</h3>
                    <p class="trust-desc">Disusun dalam satu halaman dengan bahasa yang mudah dipahami. Bukan barisan angka tanpa cerita — Anda mendapat kejelasan: mana yang berjalan optimal, dan mana yang perlu disesuaikan.</p>
                </div>
                <div class="trust-item" style="animation-delay: 440ms;">
                    <div class="trust-icon">📅</div>
                    <h3 class="trust-title">Tanpa kontrak minimum</h3>
                    <p class="trust-desc">Sistem kerja bulanan. Anda bebas lanjut atau berhenti kapan saja — tanpa kontrak panjang yang lazim di kebanyakan agency.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== TESTIMONIALS ====================== -->
    <Testimonials client:only="svelte" />

    <!-- ====================== FAQ ====================== -->
    <section id="faq" class="py-20 md:py-28 bg-soft relative overflow-hidden">
        <svg class="absolute -left-12 top-16 w-40 h-40 opacity-40 hidden md:block faq-deco" viewBox="0 0 100 100" aria-hidden="true">
            <defs>
                <linearGradient id="faqGrad1" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.5"/>
                    <stop offset="100%" stop-color="#f59e0b" stop-opacity="0"/>
                </linearGradient>
            </defs>
            <circle cx="50" cy="50" r="42" fill="none" stroke="url(#faqGrad1)" stroke-width="2" stroke-dasharray="4 6"/>
            <circle cx="50" cy="50" r="28" fill="none" stroke="#f59e0b" stroke-opacity="0.3" stroke-width="1.5"/>
            <text x="50" y="58" text-anchor="middle" font-size="36" font-weight="900" fill="#f59e0b" fill-opacity="0.2">?</text>
        </svg>
        <svg class="absolute -right-10 bottom-24 w-28 h-28 opacity-50 hidden md:block" viewBox="0 0 100 100" aria-hidden="true">
            <circle cx="50" cy="50" r="35" fill="none" stroke="#0ea5e9" stroke-opacity="0.25" stroke-width="2" stroke-dasharray="2 5"/>
            <circle cx="50" cy="50" r="6" fill="#0ea5e9" fill-opacity="0.3">
                <animate attributeName="r" values="6;9;6" dur="2.5s" repeatCount="indefinite"/>
            </circle>
        </svg>
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Sebelum mulai, ini biasanya yang ditanya
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Pertanyaan yang sering muncul<br/>
                    <span class="text-accent">sebelum deal pertama.</span>
                </h2>
            </div>
            <Faq client:only="svelte" />
        </div>
    </section>

    <!-- ====================== FINAL CTA ====================== -->
    <section class="py-20 md:py-28 bg-gradient-to-br from-ink via-primary-2 to-ink text-white relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none opacity-[0.08] cta-grid"></div>
        <div class="abs-radaial-2"></div>

        <div class="floating-emoji emoji-1 hidden lg:flex">📈</div>
        <div class="floating-emoji emoji-2 hidden lg:flex">💬</div>
        <div class="floating-emoji emoji-3 hidden lg:flex">🚀</div>

        <div class="container mx-auto px-6 relative">
            <div class="max-w-3xl mx-auto text-center reveal">
                <a href="https://socio.id" target="_blank" rel="noopener nofollow" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full text-xs font-bold uppercase tracking-wider mb-6 hover:bg-white/15 transition-colors">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
                    </span>
                    socio.id
                </a>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight mb-6 mt-3">
                    Tunjukkan kami<br/>
                    <span class="text-accent">Ads Manager Anda.</span>
                </h2>
                <p class="text-white/70 text-base md:text-lg max-w-xl mx-auto mb-10 leading-relaxed">
                    Tim kami akan menelaah iklan Meta, Google, atau TikTok Anda secara cuma-cuma — lalu menyusun rekomendasi tertulis yang bisa langsung dijalankan, dalam 24 jam kerja.
                </p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-accent text-ink px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine-accent">
                        <span class="relative z-10 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:rotate-12 transition" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24z"/></svg>
                            Mulai Diskusi via WhatsApp
                        </span>
                    </a>
                    <a href="mailto:info@beriklan.co.id" class="inline-flex items-center justify-center gap-2 border border-white/20 text-white font-bold px-7 py-4 rounded-full hover:bg-white/5 hover:-translate-y-1 transition-all">
                        Atau email ke info@beriklan.co.id
                    </a>
                </div>
                <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-white/55">
                    <span class="flex items-center gap-1.5"><span class="check-icon-dark"></span> Minimum kerja 1 bulan</span>
                    <span class="flex items-center gap-1.5"><span class="check-icon-dark"></span> Berhenti kapan saja tanpa penalti</span>
                    <span class="flex items-center gap-1.5"><span class="check-icon-dark"></span> Pricing transparan, tanpa markup ad spend</span>
                </div>
            </div>
        </div>
    </section>

    <Footer />
</Layout>

<style is:global>
    /* ====================== ANIMATIONS ====================== */

    /* Fade up baseline */
    .anim-fade-up {
        animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
    }
    .anim-fade-in {
        animation: fadeIn 0.6s ease 0.4s forwards;
    }
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    /* Scroll cue + hero floating */
    .scroll-cue { animation: bounce-soft 2s ease-in-out infinite; }
    @keyframes bounce-soft {
        0%, 100% { transform: translate(-50%, 0); }
        50% { transform: translate(-50%, 6px); }
    }

    /* Hero grid pattern */
    .hero-grid {
        background-image: linear-gradient(rgba(15,30,61,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(15,30,61,.04) 1px, transparent 1px);
        background-size: 48px 48px;
    }

    /* Decorative blobs (GPU-accelerated) */
    .abs-blob {
        position: absolute; border-radius: 9999px;
        pointer-events: none; will-change: transform;
        transform: translateZ(0);
    }
    .abs-blob-1 {
        top: 5rem; right: -8rem;
        width: 420px; height: 420px;
        background: rgba(245, 158, 11, 0.10);
        filter: blur(48px);
        animation: float-shape 14s ease-in-out infinite;
    }
    .abs-blob-2 {
        bottom: 0; left: -5rem;
        width: 288px; height: 288px;
        background: rgba(14, 165, 233, 0.10);
        filter: blur(40px);
        animation: float-shape 11s ease-in-out infinite 1.5s;
    }
    @keyframes float-shape {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(0, -16px); }
    }

    /* CTA grid background */
    .cta-grid {
        background-image: linear-gradient(rgba(255,255,255,.4) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.4) 1px, transparent 1px);
        background-size: 56px 56px;
    }

    /* Radial bg for dark sections */
    .abs-radaial-1, .abs-radaial-2 {
        position: absolute; inset: 0; pointer-events: none;
    }
    .abs-radaial-1 {
        background:
            radial-gradient(circle at 85% 15%, rgba(245, 158, 11, 0.18) 0%, transparent 40%),
            radial-gradient(circle at 15% 85%, rgba(14, 165, 233, 0.14) 0%, transparent 40%);
    }
    .abs-radaial-2 {
        background:
            radial-gradient(circle at 85% 15%, rgba(245, 158, 11, 0.20) 0%, transparent 40%),
            radial-gradient(circle at 15% 85%, rgba(14, 165, 233, 0.15) 0%, transparent 40%);
    }

    /* Check icons (reusable) */
    .check-icon {
        width: 1.25rem; height: 1.25rem; border-radius: 9999px;
        background: rgba(16, 185, 129, 0.1);
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .check-icon::after {
        content: ""; width: 0.75rem; height: 0.75rem;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20' fill='%2310b981'><path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'/></svg>");
        background-size: contain; background-repeat: no-repeat;
    }
    .check-icon-dark {
        width: 0.875rem; height: 0.875rem;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20' fill='%23f59e0b'><path fill-rule='evenodd' d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z' clip-rule='evenodd'/></svg>");
        background-size: contain; background-repeat: no-repeat;
        display: inline-block;
    }

    /* Stats dark cards — animated on scroll into view */
    .stat-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(245, 158, 11, 0.18);
        border-radius: 1rem;
        padding: 1.5rem;
        text-align: center;
        transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        backdrop-filter: blur(8px);
    }
    .stat-card:hover {
        border-color: rgba(245, 158, 11, 0.5);
        transform: translateY(-4px);
        box-shadow: 0 16px 40px -8px rgba(245, 158, 11, 0.25);
    }
    .stat-num {
        font-family: "Plus Jakarta Sans Variable", sans-serif;
        font-weight: 800; font-size: 2.75rem; line-height: 1;
        background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        -webkit-background-clip: text; background-clip: text; color: transparent;
        margin-bottom: 0.5rem;
    }
    .stat-label { font-size: 0.875rem; color: rgba(255, 255, 255, 0.8); font-weight: 600; }
    .stat-bar {
        position: relative; height: 4px;
        background: rgba(255, 255, 255, 0.08); border-radius: 9999px;
        overflow: hidden; margin-top: 0.875rem;
    }
    .stat-bar span {
        position: absolute; inset: 0;
        background: linear-gradient(90deg, #f59e0b, #fbbf24);
        border-radius: 9999px;
        transform-origin: left;
        animation: bar-fill 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
    }
    @keyframes bar-fill { from { transform: scaleX(0); } to { transform: scaleX(1); } }
    .stat-foot { margin-top: 0.5rem; font-size: 0.6875rem; color: rgba(255, 255, 255, 0.4); font-weight: 600; }

    /* Trust items hover */
    .trust-item {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1rem;
        padding: 1.5rem;
        transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    }
    .trust-item:hover {
