ss", "priceLabel": "3.750.000", "duration": "30 hari tayang", "highlight": true, "tagline": "Untuk bisnis yang ingin jangkauan lebih luas dan optimasi lebih agresif.", "features": ["Estimasi jangkauan 4.000-15.000 orang per hari", "Penayangan di seluruh placement Facebook", "3 iklan aktif: 10 foto atau 1 video per iklan", "Iklan dapat diganti kapan saja di tengah periode", "Setup remarketing + lookalike audience", "Laporan mingguan + review bulanan via video call", "Akses penuh ke akun iklan Facebook Anda"], "priceNote": "belum termasuk ad spend Meta", "disclaimer": "Tanpa kontrak panjang. Berhenti kapan saja."}], "why_features": [{"icon": "🎯", "title": "Targeting Akurat", "desc": "Lebih dari 100 kategori minat, perilaku, dan demografi yang dapat dikombinasikan. Kami memilih kombinasi yang paling sesuai dengan karakter audiens Anda."}, {"icon": "📊", "title": "Data yang Terbaca", "desc": "Dashboard Meta menampilkan data detail tentang siapa yang melihat, mengklik, dan berkonsultasi — semuanya bisa Anda cek sendiri."}, {"icon": "💬", "title": "Chat WhatsApp Langsung", "desc": "Tombol Call-to-Action bawaan Meta mengirim klik langsung ke WhatsApp — mempersempit jarak dari 'tertarik' menjadi 'percakapan'."}], "how_steps": [{"num": "01", "tag": "MINGGU 1", "title": "Brief & Riset", "desc": "Diskusi 30 menit untuk menggali produk, target market, dan tujuan Anda. Kami susun strategi targeting yang sesuai."}, {"num": "02", "tag": "MINGGU 1-2", "title": "Setup & Kreatif", "desc": "Kami siapkan akun iklan & Meta Pixel, dan materi iklan (foto, video, copy). Anda approve, kami eksekusi."}, {"num": "03", "tag": "MINGGU 2+", "title": "Launch 30 Hari", "desc": "Iklan tayang selama 30 hari penuh di seluruh placement Facebook. Anda menerima laporan setiap Senin pagi."}, {"num": "04", "tag": "ONGOING", "title": "Optimasi & Ganti Iklan", "desc": "Kami monitor performa harian. Iklan yang tidak perform diganti. Yang jalan, di-scale-up."}], "city_intro_template": "", "testimonials": [{"quote": "ROAS kami meningkat dari 1.8x menjadi 4.5x dalam empat bulan. Yang paling kami apresiasi: laporan disusun dengan bahasa yang jelas dan setiap perubahan dapat kami pahami.", "author": "Andini Pratiwi", "role": "Owner · Brand Skincare, Bandung", "metric": "ROAS 1.8x → 4.5x dalam 4 bulan", "avatar": "🧴", "color": "from-amber-500 to-orange-500"}, {"quote": "Setiap Senin pagi selalu ada laporan dalam bahasa yang mudah dipahami — bukan hanya deretan CPM dan CTR, tetapi apa yang perlu diubah dan mengapa.", "author": "Rizky Maulana", "role": "Marketing Manager · Klinik Kecantikan, Jakarta", "metric": "Lead konsisten 3x lipat dari bulan ke-2", "avatar": "💆", "color": "from-pink-500 to-rose-500"}, {"quote": "Karakteristik funnel B2B berbeda signifikan dari FMCG. Beriklan memahami hal ini dan menyusun strategi yang relevan. Qualified leads naik 180% di Q3.", "author": "Sarah Nathania", "role": "Head of Growth · SaaS B2B, Jakarta", "metric": "Qualified leads +180% di Q3 2025", "avatar": "💼", "color": "from-blue-500 to-indigo-500"}]};
