---
import Layout from '../layouts/Layout.astro';

import Navbar from '../components/Navbar.svelte';
import StickyCTA from '../components/StickyCTA.svelte';
import YouTubePlayerMock from '../components/YouTubePlayerMock.svelte';
import PricingCards from '../components/PricingCards.svelte';
import FaqAccordion from '../components/FaqAccordion.svelte';
import PAASection from '../components/PAASection.astro';
import RelatedServices from '../components/RelatedServices.svelte';
import FeatureGrid from '../components/FeatureGrid.svelte';
import StepGrid from '../components/StepGrid.svelte';
import StatsBand from '../components/StatsBand.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import AuthorBio from '../components/AuthorBio.astro';
import Footer from '../components/Footer.svelte';
import relatedMap from '../data/related-services.json';
import { MessageCircle, ArrowRight, Target, Sparkles, Repeat, MapPin, Database, Users, Check, TrendingUp } from 'lucide-svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20tertarik%20dengan%20jasa%20iklan%20YouTube.%20Mohon%20info%20paket%20dan%20harga.";

const tiers = [
    {
        name: 'Basic',
        priceLabel: '1.250.000',
        duration: '14 hari tayang',
        tagline: 'Untuk testing awal atau campaign jangka pendek dengan format non-skippable.',
        features: [
            'Estimasi 35.000 tayangan',
            'Format non-skippable 6-15 detik',
            'Targeting interest + demographics',
            'Penayangan di YouTube partner',
            'Laporan akhir periode',
            'Akses penuh ke akun Google Ads',
        ],
        priceNote: 'belum termasuk ad spend YouTube',
        disclaimer: 'Tanpa kontrak panjang. Berhenti kapan saja.',
    },
    {
        name: 'Starter',
        priceLabel: '2.500.000',
        duration: '30 hari tayang',
        tagline: 'Untuk campaign brand awareness dengan format non-skippable yang lebih stabil.',
        features: [
            'Estimasi 75.000 tayangan',
            'Format non-skippable 15 detik',
            'Targeting interest + demographics',
            'Penayangan di YouTube partner',
            'Laporan akhir periode',
            'Akses penuh ke akun Google Ads',
        ],
        priceNote: 'belum termasuk ad spend YouTube',
        disclaimer: 'Tanpa kontrak panjang. Berhenti kapan saja.',
    },
    {
        name: 'Standart',
        priceLabel: '3.750.000',
        duration: '30 hari tayang',
        tagline: 'Untuk campaign yang mengarahkan viewers ke action — visit channel, klik website, atau WhatsApp.',
        features: [
            'Estimasi ~10.000 views',
            'Format skippable (viewer dapat skip setelah 5 detik)',
            'Call-to-action overlay',
            'Targeting interest + demographics + placement',
            'A/B testing thumbnail',
            'Laporan akhir periode',
            'Akses penuh ke akun Google Ads',
        ],
        priceNote: 'belum termasuk ad spend YouTube',
        disclaimer: 'Tanpa kontrak panjang. Berhenti kapan saja.',
        highlight: true,
    },
    {
        name: 'Business',
        priceLabel: '4.750.000',
        duration: '30 hari tayang',
        tagline: 'Untuk campaign dengan jangkauan luas dan kombinasi format skippable + non-skippable.',
        features: [
            'Estimasi 50.000 tayangan + ~8.000 views',
            'Format skippable + non-skippable',
            'Call-to-action overlay + cards',
            'Targeting interest + demographics + placement + keywords',
            'A/B testing thumbnail & copy',
            'Setup conversion tracking',
            'Laporan akhir periode + review strategi',
            'Akses penuh ke akun Google Ads',
        ],
        priceNote: 'belum termasuk ad spend YouTube',
        disclaimer: 'Tanpa kontrak panjang. Berhenti kapan saja.',
    },
];

const features = [
    { iconName: 'Video', title: 'Format Video Beragam', desc: 'Pilih format: bumper 6 detik, non-skippable 15 detik, atau skippable 30 detik. Setiap format punya peran berbeda dalam funnel.' },
    { iconName: 'Target', title: 'Targeting Interest', desc: 'Jangkau audiens berdasarkan minat spesifik: beauty, parenting, automotive, dan 100+ kategori lainnya. Penargetan hingga demographic detail.' },
    { iconName: 'MapPin', title: 'Target Wilayah', desc: 'Batasi penayangan ke kota atau provinsi tertentu. Cocok untuk bisnis lokal yang hanya beroperasi di area spesifik.' },
    { iconName: 'Sparkles', title: 'Placement Targeting', desc: 'Pilih channel YouTube spesifik tempat iklan Anda muncul — misalnya hanya di channel edukasi, atau hanya di channel review produk.' },
    { iconName: 'Eye', title: 'Keyword Targeting', desc: 'Iklan muncul di video yang mengandung kata kunci tertentu — cara tepat untuk konteks yang relevan.' },
    { iconName: 'TrendingUp', title: 'Brand Lift Measurement', desc: 'Untuk paket Business, kami mengukur brand lift untuk melihat dampak campaign terhadap persepsi audiens terhadap brand Anda.' },
];

const steps = [
    { num: '01', tag: 'MINGGU 1', title: 'Brief & Konsep Video', desc: 'Diskusi 30 menit untuk menggali produk, target market, dan tone video yang sesuai dengan brand. Kami bantu susun storyboard dan script jika diperlukan.' },
    { num: '02', tag: 'MINGGU 1-2', title: 'Produksi Video', desc: 'Anda menyediakan video yang siap tayang, atau kami rekomendasikan partner produksi. Video minimal 6 detik (bumper) atau 15-30 detik (skippable). Anda approve hasil akhir.' },
    { num: '03', tag: 'MINGGU 2+', title: 'Launch Campaign', desc: 'Video tayang di YouTube sesuai durasi paket yang dipilih (14 atau 30 hari). Targeting yang sudah disesuaikan memastikan video muncul di depan audiens yang relevan.' },
    { num: '04', tag: 'ONGOING', title: 'Optimasi & Laporan', desc: 'Kami monitor watch time, CTR, dan konversi setiap minggu. Video yang watch time-nya rendah akan kami rekomendasikan iterasi script. Laporan disusun dengan bahasa yang mudah dipahami.' },
];

const faqs = [
    { q: 'Berapa budget iklan (ad spend) yang perlu disiapkan di luar biaya jasa?', a: 'Tergantung target jangkauan dan industri. Untuk YouTube Ads di Indonesia, umumnya mulai dari Rp 50.000-100.000 per hari untuk campaign yang stabil, atau lebih tinggi tergantung targeting dan format. Pada sesi konsultasi, kami bantu estimasi ad spend yang ideal berdasarkan objective Anda.' },
    { q: 'Apakah harga paket sudah termasuk ad spend YouTube?', a: 'Belum. Angka tersebut adalah biaya jasa pengelolaan campaign. Ad spend Meta dibayar langsung ke Meta oleh Anda — Anda memegang penuh kendali akun, tidak ada biaya tersembunyi lewat kami.' },
    { q: 'Berapa lama sampai iklan mulai menghasilkan chat WhatsApp atau leads?', a: 'Untuk paket 14 hari (Basic), data sudah terbaca di akhir periode. Untuk paket 30 hari (Starter/Standart/Business), pola yang lebih stabil biasanya terlihat di minggu ke-3 atau ke-4. Bisa lebih cepat atau lambat tergantung kualitas video dan targeting.' },
    { q: 'Bisakah iklan diganti di tengah periode berjalan?', a: 'Bisa, dan ini salah satu keuntungan paket kami. Jika Creative A tidak perform, kami ganti dengan Creative B di tengah jalan. Hal yang sama pada copy, audience, atau placement yang perlu disesuaikan.' },
    { q: 'Apakah ada kontrak minimum?', a: 'Tidak ada. Sistem kami bekerja secara bulanan. Anda bebas memutuskan untuk lanjut atau berhenti setiap periode. Ini bentuk komitmen kami untuk menjaga kualitas kerja — bukan jebakan kontrak.' },
    { q: 'Apa bedanya paket Basic, Starter, Standart, dan Business?', a: 'Basic (14 hari, format non-skippable 6-15 detik, ~35.000 tayangan) untuk testing awal. Starter (30 hari, non-skippable 15 detik, ~75.000 tayangan) untuk brand awareness. Standart (30 hari, skippable, ~10.000 views, CTA overlay) untuk mengarahkan viewers ke action. Business (30 hari, skippable + non-skippable, ~50.000 tayangan + ~8.000 views, conversion tracking) untuk jangkauan luas dan konversi terukur.' },
    { q: 'Bagaimana laporan yang diberikan?', a: 'Laporan mingguan disusun dalam satu halaman dengan bahasa yang mudah dipahami — bukan sekadar deretan CPM-CTR-CPC. Anda mendapat kejelasan: mana yang berjalan optimal, mana yang perlu disesuaikan, dan rencana aksi untuk minggu depan.' },
];

const relatedItems = (relatedMap.services['jasa-iklan-youtube'] || []).map(item => ({
  icon: item.icon,
  label: item.label,
  desc: item.desc,
  href: '/' + item.slug + '/',
}));
---

<Layout title="Jasa Iklan YouTube Indonesia | Mulai Rp 1,25 Juta — Beriklan" description="Video ads YouTube yang membangun brand awareness & menghasilkan action. TrueView, Bumper, In-Stream — pilihan format untuk setiap objective. Mulai Rp 1,25 juta per 14 hari. Sertifikat Google Partner." canonical="https://beriklan.co.id/jasa-iklan-youtube/"
    faq={[
            { question: 'Berapa biaya YouTube Ads?', answer: 'Mulai dari Rp 1.750.000 per 30 hari. Sudah termasuk setup TrueView, Bumper Ads, dan optimasi.' },
            { question: 'Format YouTube Ads apa saja?', answer: 'TrueView In-Stream (skippable setelah 5 detik), Bumper Ads (6 detik non-skippable), Discovery Ads (muncul di YouTube home).' },
            { question: 'Apakah YouTube Ads untuk brand awareness?', answer: 'Sangat efektif. YouTube punya reach 50jt+ user Indonesia per bulan. Cocok untuk brand awareness + consideration.' },
            { question: 'Berapa lama setup YouTube Ads?', answer: 'Setup 2-5 hari (perlu video assets). Iklan live setelah approval YouTube (1-3 hari).' },
            { question: 'YouTube Ads cocok untuk industri apa?', answer: 'Semua industri. Terutama efektif untuk FMCG, tech, education, financial services, automotive.' }
        ]}
    breadcrumb={[
        { name: "Beranda", url: "https://www.beriklan.co.id/" },
        { name: "Jasa Iklan YouTube", url: "https://www.beriklan.co.id/jasa-iklan-youtube/" }
    ]}
    service={{
        name: "Jasa Iklan YouTube",
        description: "Jasa Jasa Iklan YouTube profesional dari Beriklan.co.id. Tim bersertifikat, strategi terukur, laporan mingguan, dan optimasi rutin untuk UMKM & bisnis menengah di Indonesia.",
        url: "https://www.beriklan.co.id/jasa-iklan-youtube/",
        priceRange: "Rp 1.750.000 - Rp 3.750.000",
        serviceType: "YouTube Ads",
        areaServed: "Indonesia",
        provider: { name: "Beriklan.co.id", url: "https://www.beriklan.co.id" }
    }}
>>

    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <!-- ====================== HERO ====================== -->
    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-24 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="abs-blob abs-blob-1"></div>
        <div class="abs-blob abs-blob-2"></div>

        <svg class="absolute left-1/2 -translate-x-1/2 top-32 w-40 h-12 opacity-30 hidden lg:block" viewBox="0 0 160 40" aria-hidden="true">
            <path d="M5,20 Q40,5 80,20 T155,20" stroke="#0f1e3d" stroke-width="1.5" fill="none" stroke-dasharray="3 5"/>
        </svg>

        <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
            <div class="space-y-7 text-center lg:text-left">
                <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
                    </span>
                    <span class="opacity-0 anim-fade-in">Jasa Iklan YouTube · Video Ads & Awareness</span>
                </div>

                <h1 class="hero-h1 font-display font-extrabold text-4xl md:text-5xl lg:text-[2.6rem] xl:text-[2.9rem] text-ink leading-[1.05] tracking-tight">
                    <span class="anim-fade-up">Jasa Iklan YouTube</span><br/>
                    <span class="anim-fade-up text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent" style="animation-delay: 80ms;">Bangun Brand Awareness</span><br/>
                    <span class="anim-fade-up" style="animation-delay: 160ms;">Lewat Video.</span>
                </h1>

                <p class="hero-sub text-base md:text-lg text-muted leading-relaxed max-w-xl mx-auto lg:mx-0 anim-fade-up" style="animation-delay: 240ms;">
                    YouTube adalah platform video terbesar di Indonesia dengan jutaan penonton aktif setiap hari. Kami membantu bisnis Anda menayangkan iklan video yang tertarget — agar pesan Anda dilihat oleh audiens yang tepat, di channel yang tepat, di saat yang tepat.
                </p>

                <div class="hero-ctas flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2 anim-fade-up" style="animation-delay: 320ms;">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-ink text-white px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine">
                        <span class="relative z-10 flex items-center gap-2">
                            Diskusi via WhatsApp
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 group-hover:rotate-12 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                    </a>
                    <a href="#pricing" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full font-bold text-ink border border-gray-200 bg-white hover:border-ink hover:-translate-y-0.5 transition-all">
                        Lihat Paket & Harga
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </a>
                </div>

                <div class="hero-trust pt-6 border-t border-gray-200/60 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-xs md:text-sm reveal" style="transition-delay: 200ms;">
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted"><strong class="text-ink">9 tahun</strong> mengelola campaign iklan</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Optimasi berbasis data, bukan tebakan</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Laporan <strong class="text-ink">setiap Senin</strong>, bahasa yang mudah dipahami</span></div>
                </div>
            </div>

            <div class="relative flex justify-center lg:justify-end anim-fade-up" style="animation-delay: 400ms;">
                <YouTubePlayerMock client:only="svelte" />
            </div>
        </div>
    </header>

    <!-- ====================== TRUST BAR ====================== -->
    <section class="py-7 bg-ink border-y border-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
                <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.18em] text-white/40">Dipercaya bisnis dari berbagai industri</p>
                <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-white/70 text-sm font-semibold trust-word">
                    <span>F&amp;B</span><span class="text-white/30">·</span>
                    <span>Skincare</span><span class="text-white/30">·</span>
                    <span>Fashion</span><span class="text-white/30">·</span>
                    <span>Edutech</span><span class="text-white/30">·</span>
                    <span>SaaS B2B</span><span class="text-white/30">·</span>
                    <span>Klinik</span><span class="text-white/30">·</span>
                    <span>Properti</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== STATS BAND ====================== -->
    <StatsBand />

    <!-- ====================== WHY FACEBOOK ADS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Kenapa YouTube Ads
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Bukan sekadar tayang di YouTube,<br/>
                    <span class="text-accent">tapi video yang membangun brand dan trust.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    YouTube adalah platform pencarian terbesar kedua di dunia setelah Google — terutama untuk konten edukatif dan review. Iklan video Anda muncul sebelum, selama, atau setelah video yang ditonton audiens. Kekuatan video: mampu menjelaskan value produk dalam 15-30 detik dengan lebih persuasif daripada teks.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="why-card group">
                    <div class="why-icon">🎯</div>
                    <h3 class="why-title">Penargetan Audiens Tertarget</h3>
                    <p class="why-desc">YouTube Ads memungkinkan targeting berdasarkan interest, demographics, hingga penempatan di channel spesifik. Kami pilih kombinasi yang sesuai dengan bisnis Anda.</p>
                </div>
                <div class="why-card group" style="animation-delay: 100ms;">
                    <div class="why-icon">📊</div>
                    <h3 class="why-title">Brand Awareness yang Terukur</h3>
                    <p class="why-desc">Dashboard iklan YouTube menampilkan views, watch time, dan brand lift. Anda dapat melihat apakah video Anda ditonton sampai habis atau di-skip di detik ke-5.</p>
                </div>
                <div class="why-card group" style="animation-delay: 200ms;">
                    <div class="why-icon">💬</div>
                    <h3 class="why-title">Format Fleksibel</h3>
                    <p class="why-desc">Pilih format: skippable, non-skippable, bumper 6 detik, atau in-feed. Setiap format memiliki keunggulan masing-masing tergantung objective Anda.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== FEATURES GRID ====================== -->
    <section id="fitur" class="py-20 md:py-28 bg-soft relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    6 Kemampuan Targeting
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Fitur yang kami optimalkan<br/>
                    <span class="text-accent">di setiap campaign.</span>
                </h2>
            </div>

            <FeatureGrid items={features} client:visible />
        </div>
    </section>

    <!-- ====================== HOW IT WORKS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(15,30,61,0.05) 1px, transparent 0); background-size: 32px 32px;"></div>

        <div class="container mx-auto px-6 relative">
            <div class="max-w-2xl mx-auto text-center mb-14 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-6 h-px bg-accent"></span>
                    Cara Kerja
                    <span class="w-6 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Empat langkah dari brief<br/>
                    <span class="text-accent">menuju iklan yang tayang optimal.</span>
                </h2>
            </div>

            <StepGrid items={steps} client:visible />
        </div>
    </section>

    <!-- ====================== PRICING ====================== -->
    <section id="pricing" class="py-20 md:py-28 bg-gradient-to-br from-soft via-white to-beige relative overflow-hidden">
        <div class="abs-blob abs-blob-3"></div>
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Paket & Harga
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Dua paket, disesuaikan dengan<br/>
                    <span class="text-accent">tujuan bisnis Anda.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    Pilih paket sesuai objective campaign: Standart untuk jangkauan rutin, Business untuk skala lebih besar dengan remarketing aktif.
                </p>
            </div>

            <PricingCards tiers={tiers} pageSlug="YouTube Ads" highlightIndex={2} columns={4} client:only="svelte" />

            <div class="mt-10 max-w-2xl mx-auto reveal">
                <div class="bg-white rounded-2xl border border-gray-100 p-5 md:p-6 shadow-soft">
                    <div class="flex items-start gap-3">
                        <div class="w-10 h-10 rounded-xl bg-accent/15 flex items-center justify-center shrink-0">
                            <Check class="w-5 h-5 text-accent" strokeWidth="2.5" />
                        </div>
                        <div>
                            <p class="font-display font-bold text-base text-ink mb-1">Tidak yakin paket mana yang sesuai?</p>
                            <p class="text-sm text-muted leading-relaxed">Sesi konsultasi 15 menit gratis. Kami bantu pilih paket yang paling cocok dengan budget iklan dan objective campaign Anda.</p>
                            <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 mt-3 text-sm font-bold text-accent hover:text-ink transition-colors group">
                                Konsultasi via WhatsApp
                                <ArrowRight class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== COMPARISON TABLE ====================== -->
    <ComparisonTable serviceName="Iklan YouTube" />

    <!-- ====================== STATS / TRUST ====================== -->
    <section class="py-20 md:py-28 bg-ink text-white relative overflow-hidden">
        <div class="abs-radaial-1"></div>
        <div class="stat-orb stat-orb-1"></div>
        <div class="stat-orb stat-orb-2"></div>

        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Mengapa Tim Ini
                    <span class="w-8 h-px bg-accent"></span>
                </p>
