---
import Layout from '../layouts/Layout.astro';

import Navbar from '../components/Navbar.svelte';
import StickyCTA from '../components/StickyCTA.svelte';
import SiteBuilderMock from '../components/SiteBuilderMock.svelte';
import PricingCards from '../components/PricingCards.svelte';
import FaqAccordion from '../components/FaqAccordion.svelte';
import RelatedServices from '../components/RelatedServices.svelte';
import FeatureGrid from '../components/FeatureGrid.svelte';
import StepGrid from '../components/StepGrid.svelte';
import Footer from '../components/Footer.svelte';
import TechStack from '../components/TechStack.svelte';
import { MessageCircle, ArrowRight, Target, Sparkles, Repeat, MapPin, Database, Users, Check, TrendingUp, Zap, Smartphone, Lock, Search, Eye, Layers, Code, Server, Shield, Globe, FileText, Mail, MessageSquare, Briefcase, HeartHandshake, Sprout, Building2, BarChart3, SproutIcon } from 'lucide-svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20tertarik%20dengan%20jasa%20pembuatan%20website.%20Mohon%20info%20paket%20dan%20harga.";

const tiers = [
    {
        name: 'Basic (Starter)',
        priceLabel: '999.000',
        duration: '1 tahun',
        tagline: 'Untuk UMKM atau personal brand yang membutuhkan landing page profesional.',
        features: [
            '1 halaman landing',
            '1 akun email profesional',
            '1x revisi desain',
            'Basic SEO setup',
            'SSL + responsive design',
            'Domain + hosting 1 tahun',
        ],
        priceNote: 'sudah termasuk domain & hosting 1 tahun',
        disclaimer: 'Perpanjangan tahun berikutnya di luar paket.',
    },
    {
        name: 'Professional (Corporate)',
        priceLabel: 'Call us',
        duration: '1 tahun',
        tagline: 'Untuk bisnis yang membutuhkan company profile multi-halaman dengan desain premium.',
        features: [
            '5 halaman (Home, About, Services, Portfolio, Contact)',
            '5 akun email profesional',
            '2x revisi desain',
            'Basic SEO setup + Google Analytics',
            'SSL + responsive design',
            'Domain + hosting 1 tahun',
            'CMS untuk update konten sendiri',
        ],
        priceNote: 'harga disesuaikan dengan kompleksitas',
        disclaimer: 'Perpanjangan tahun berikutnya di luar paket.',
        highlight: true,
    },
    {
        name: 'Business (E-commerce)',
        priceLabel: 'Call us',
        duration: '1 tahun',
        tagline: 'Untuk bisnis yang membutuhkan toko online dengan integrasi payment & shipping.',
        features: [
            'Hingga 25 halaman + katalog produk',
            '25 akun email profesional',
            '3x revisi desain',
            'Basic SEO + product schema',
            'SSL + responsive design',
            'Domain + hosting 1 tahun',
            'Payment gateway (Midtrans, Xendit, dll.)',
            'Shipping gateway (JNE, J&T, SiCepat)',
            'CMS + dashboard admin',
        ],
        priceNote: 'harga disesuaikan dengan kompleksitas',
        disclaimer: 'Perpanjangan tahun berikutnya di luar paket.',
    },
];

const features = [
    { iconName: 'Smartphone', title: 'Responsive Design', desc: 'Website tampil sempurna di desktop, tablet, dan mobile. Standar industri saat ini yang menjadi keharusan.' },
    { iconName: 'Zap', title: 'Fast Load Time', desc: 'Dioptimasi untuk kecepatan: page load di bawah 3 detik. Pengalaman cepat meningkatkan konversi dan ranking SEO.' },
    { iconName: 'Search', title: 'SEO Ready', desc: 'Struktur website ramah mesin pencari: meta tags, schema markup, sitemap XML. Fondasi untuk ditemukan di Google.' },
    { iconName: 'Lock', title: 'SSL & Security', desc: 'Sertifikat SSL untuk HTTPS, monitoring uptime, dan backup rutin. Website aman dan selalu dapat diakses.' },
    { iconName: 'Eye', title: 'Conversion Focused', desc: 'Setiap elemen didesain untuk mengarah ke action: WhatsApp button, form kontak, atau katalog produk.' },
    { iconName: 'Layers', title: 'CMS (untuk paket tertentu)', desc: 'Paket Professional dan Business termasuk CMS sehingga Anda dapat update konten sendiri tanpa coding.' },
];

const steps = [
    { num: '01', tag: 'HARI 1-3', title: 'Brief & Riset', desc: 'Diskusi 30 menit untuk menggali produk, target market, dan referensi desain. Kami susun sitemap dan wireframe sebagai pondasi.' },
    { num: '02', tag: 'HARI 4-10', title: 'Desain & Development', desc: 'Tim kami desain visual dan develop website. Anda melihat progress secara berkala dan memberikan feedback.' },
    { num: '03', tag: 'HARI 11-14', title: 'Testing & Revisi', desc: 'Website diuji di berbagai device dan browser. Anda mencoba dan memberikan feedback revisi (sesuai paket).' },
    { num: '04', tag: 'HARI 15+', title: 'Launch & Handover', desc: 'Website live, domain aktif, email profesional siap dipakai. Tim kami memberikan training singkat untuk pengelolaan mandiri (untuk paket Professional dan Business).' },
];

const faqs = [
    { q: 'Apa yang sudah termasuk dalam setiap paket?', a: 'Semua paket sudah termasuk domain (.com/.id/.co.id) dan hosting 1 tahun, SSL, responsive design, dan setup SEO dasar. Paket Professional dan Business menambahkan CMS untuk update konten sendiri, Google Analytics, dan integrasi payment gateway.' },
    { q: 'Apakah domain dan hosting sudah termasuk?', a: 'Ya, untuk tahun pertama. Perpanjangan tahun depan menyesuaikan harga berlaku (biasanya Rp 350rb–500rb/tahun untuk domain + hosting standar). Kami ingatkan sebelum masa berlaku berakhir.' },
    { q: 'Berapa lama website live?', a: 'Untuk paket Basic, 7–14 hari. Untuk paket Professional (multi-halaman), 14–21 hari. Untuk paket Business (e-commerce), 21–30 hari karena ada setup payment gateway dan testing yang lebih detail.' },
    { q: 'Bisakah website di-update sendiri setelah live?', a: 'Untuk paket Basic, tidak — update konten perlu request tim kami (dikenakan biaya terpisah). Untuk paket Professional dan Business, sudah termasuk CMS sehingga Anda bisa update sendiri seperti posting blog atau ganti foto produk.' },
    { q: 'Apakah ada kontrak minimum?', a: 'Tidak ada kontrak panjang. Pembayaran satu kali untuk satu tahun masa aktif. Anda bebas memperpanjang atau tidak di tahun berikutnya.' },
    { q: 'Apa perbedaan paket Basic, Professional, dan Business?', a: 'Basic adalah 1 halaman landing untuk UMKM atau personal brand dengan budget terbatas. Professional adalah company profile multi-halaman (5 halaman) dengan CMS. Business adalah toko online lengkap dengan payment & shipping gateway.' },
    { q: 'Bagaimana proses maintenance dan update?', a: 'Untuk paket Professional dan Business, tim kami tersedia untuk maintenance dan update konten terpisah — bisa bulanan atau per request. Untuk paket Basic, update sepenuhnya lewat tim kami.' },
];

const relatedItems = [
    { icon: '🎬', label: 'Landing Page', desc: 'Halaman konversi untuk iklan: 1 LP + 1 bulan Google Ads sudah termasuk.', href: '/jasa-pembuatan-landing-page' },
    { icon: '🔍', label: 'Google Search Ads', desc: 'Trafik tertarget dari halaman pertama Google setelah website Anda live.', href: '/jasa-iklan-google' },
    { icon: '📘', label: 'Facebook Ads', desc: 'Pasang iklan Facebook untuk membawa visitor ke website baru Anda.', href: '/jasa-iklan-facebook' },
];
---

<Layout title="Jasa Pembuatan Website | Paket dari Rp 999.000/tahun — Beriklan" description="Jasa pembuatan website profesional: landing page, company profile, dan e-commerce. Responsive, SEO-ready, fast load. Paket Basic 999rb/th, Professional & Business custom.">

    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <!-- ====================== HERO ====================== -->
    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-24 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="abs-blob abs-blob-1"></div>
        <div class="abs-blob abs-blob-2"></div>

        <svg class="absolute left-1/2 -translate-x-1/2 top-32 w-40 h-12 opacity-30 hidden lg:block" viewBox="0 0 160 40" aria-hidden="true">
            <path d="M5,20 Q40,5 80,20 T155,20" stroke="#0f1e3d" stroke-width="1.5" fill="none" stroke-dasharray="3 5"/>
        </svg>

        <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
            <div class="space-y-7 text-center lg:text-left">
                <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
                    </span>
                    <span class="opacity-0 anim-fade-in">Jasa Pembuatan Website Profesional · Custom & CMS</span>
                </div>

                <h1 class="hero-h1 font-display font-extrabold text-4xl md:text-5xl lg:text-[2.6rem] xl:text-[2.9rem] text-ink leading-[1.05] tracking-tight">
                    <span class="anim-fade-up">Jasa Pembuatan Website</span><br/>
                    <span class="anim-fade-up text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent" style="animation-delay: 80ms;">Profesional, Cepat,</span><br/>
                    <span class="anim-fade-up" style="animation-delay: 160ms;">Siap Menarik Pelanggan.</span>
                </h1>

                <p class="hero-sub text-base md:text-lg text-muted leading-relaxed max-w-xl mx-auto lg:mx-0 anim-fade-up" style="animation-delay: 240ms;">
                    Website yang baik bukan sekadar tampil — ia harus load dengan cepat, responsif di semua device, mudah ditemukan di Google, dan conversion-ready. Kami bangun website Anda dengan teknologi modern dan standar industri.
                </p>

                <div class="hero-ctas flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2 anim-fade-up" style="animation-delay: 320ms;">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-ink text-white px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine">
                        <span class="relative z-10 flex items-center gap-2">
                            Diskusi via WhatsApp
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 group-hover:rotate-12 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                    </a>
                    <a href="#pricing" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full font-bold text-ink border border-gray-200 bg-white hover:border-ink hover:-translate-y-0.5 transition-all">
                        Lihat Paket & Harga
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </a>
                </div>

                <div class="hero-trust pt-6 border-t border-gray-200/60 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-xs md:text-sm reveal" style="transition-delay: 200ms;">
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted"><strong class="text-ink">9 tahun</strong> mengelola campaign iklan</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Optimasi berbasis data, bukan tebakan</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Laporan <strong class="text-ink">setiap Senin</strong>, bahasa yang mudah dipahami</span></div>
                </div>
            </div>

            <div class="relative flex justify-center lg:justify-end anim-fade-up" style="animation-delay: 400ms;">
                <SiteBuilderMock client:only="svelte" />
            </div>
        </div>
    </header>

    <!-- ====================== TRUST BAR ====================== -->
    <section class="py-7 bg-ink border-y border-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
                <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.18em] text-white/40">Dipercaya bisnis dari berbagai industri</p>
                <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-white/70 text-sm font-semibold trust-word">
                    <span>F&amp;B</span><span class="text-white/30">·</span>
                    <span>Skincare</span><span class="text-white/30">·</span>
                    <span>Fashion</span><span class="text-white/30">·</span>
                    <span>Edutech</span><span class="text-white/30">·</span>
                    <span>SaaS B2B</span><span class="text-white/30">·</span>
                    <span>Klinik</span><span class="text-white/30">·</span>
                    <span>Properti</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== WHY FACEBOOK ADS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Kenapa Jasa Website
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Bukan sekadar website yang terlihat bagus,<br/>
                    <span class="text-accent">tapi website yang menghasilkan leads.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    Website yang baik adalah pondasi digital sebuah bisnis: ia menjadi pusat dari seluruh aktivitas online — landing untuk iklan, tempat verifikasi untuk customer, hingga katalog produk untuk transaksi. Kami bangun website dengan standar modern: fast load, SEO-ready, mobile responsive, dan conversion-focused.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="why-card group">
                    <div class="why-icon">
                        <Zap class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">Fast Load & SEO</h3>
                    <p class="why-desc">Website dioptimasi untuk kecepatan dan mesin pencari. Page speed di bawah 3 detik dan struktur SEO yang baik menjadi standar.</p>
                </div>
                <div class="why-card group" style="animation-delay: 100ms;">
                    <div class="why-icon">
                        <Smartphone class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">Responsive Semua Device</h3>
                    <p class="why-desc">Website tampil sempurna di desktop, tablet, dan mobile. Lebih dari 70% traffic Indonesia berasal dari mobile — ini bukan opsi, melainkan keharusan.</p>
                </div>
                <div class="why-card group" style="animation-delay: 200ms;">
                    <div class="why-icon">
                        <Shield class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">Aman & Stabil</h3>
                    <p class="why-desc">SSL certificate, backup rutin, dan monitoring uptime. Website Anda aman dari ancaman umum dan selalu dapat diakses customer.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== FEATURES GRID ====================== -->
    <section id="fitur" class="py-20 md:py-28 bg-soft relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    6 Kemampuan Targeting
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Fitur yang kami optimalkan<br/>
                    <span class="text-accent">di setiap campaign.</span>
                </h2>
            </div>

            <FeatureGrid items={features} client:visible />
        </div>
    </section>

    <!-- ====================== HOW IT WORKS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(15,30,61,0.05) 1px, transparent 0); background-size: 32px 32px;"></div>

        <div class="container mx-auto px-6 relative">
            <div class="max-w-2xl mx-auto text-center mb-14 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-6 h-px bg-accent"></span>
                    Cara Kerja
                    <span class="w-6 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Empat langkah dari brief<br/>
                    <span class="text-accent">menuju iklan yang tayang optimal.</span>
                </h2>
            </div>

            <StepGrid items={steps} client:visible />
        </div>
    </section>

    <!-- ====================== TECH STACK ====================== -->
    <TechStack client:visible />

    <!-- ====================== PRICING ====================== -->
    <section id="pricing" class="py-20 md:py-28 bg-gradient-to-br from-soft via-white to-beige relative overflow-hidden">
        <div class="abs-blob abs-blob-3"></div>
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Paket & Harga
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Dua paket, disesuaikan dengan<br/>
                    <span class="text-accent">tujuan bisnis Anda.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    Pilih paket sesuai objective campaign: Standart untuk jangkauan rutin, Business untuk skala lebih besar dengan remarketing aktif.
                </p>
            </div>

            <PricingCards tiers={tiers} pageSlug="Pembuatan Website" highlightIndex={1} columns={3} client:only="svelte" />

            <div class="mt-10 max-w-2xl mx-auto reveal">
                <div class="bg-white rounded-2xl border border-gray-100 p-5 md:p-6 shadow-soft">
                    <div class="flex items-start gap-3">
                        <div class="w-10 h-10 rounded-xl bg-accent/15 flex items-center justify-center shrink-0">
                            <Check class="w-5 h-5 text-accent" strokeWidth="2.5" />
                        </div>
                        <div>
                            <p class="font-display font-bold text-base text-ink mb-1">Tidak yakin paket mana yang sesuai?</p>
                            <p class="text-sm text-muted leading-relaxed">Sesi konsultasi 15 menit gratis. Kami bantu pilih paket yang paling cocok dengan budget iklan dan objective campaign Anda.</p>
                            <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 mt-3 text-sm font-bold text-accent hover:text-ink transition-colors group">
                                Konsultasi via WhatsApp
                                <ArrowRight class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== STATS / TRUST ====================== -->
    <section class="py-20 md:py-28 bg-ink text-white relative overflow-hidden">
        <div class="abs-radaial-1"></div>
        <div class="stat-orb stat-orb-1"></div>
        <div class="stat-orb stat-orb-2"></div>

        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Mengapa Tim Ini
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-white leading-[1.1] tracking-tight mt-3">
                    Bukan agensi yang berjanji<br/>
                    <span class="text-accent">angka fantastis tanpa dasar.</span>
                </h2>
                <p class="text-white/60 mt-4 text-base max-w-xl mx-auto">
                    Seluruh hasil berdasarkan data riil yang dapat Anda verifikasi sendiri. Bukan janji — hanya proses yang terukur.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="trust-item-dark">
                    <div class="trust-icon-dark">
                        <Lock class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="trust-title-dark">Akses penuh ke akun Anda</h3>
                    <p class="trust-desc-dark">Seluruh akun Meta Ads tetap di bawah kendali Anda. Bila sewaktu-waktu dibutuhkan, seluruh data historis dan konfigurasi berpindah tanpa hambatan.</p>
                </div>
                <div class="trust-item-dark" style="animation-delay: 120ms;">
                    <div class="trust-icon-dark">
                        <BarChart3 class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="trust-title-dark">Laporan setiap Senin pagi</h3>
                    <p class="trust-desc-dark">Disusun dalam satu halaman dengan bahasa yang mudah dipahami. Bukan sekadar deretan CPM-CTR-CPC — Anda mendapat kejelasan: mana yang berjalan optimal, dan mana yang perlu disesuaikan.</p>
                </div>
                <div class="trust-item-dark" style="animation-delay: 240ms;">
                    <div class="trust-icon-dark">
                        <Repeat class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="trust-title-dark">Tanpa minimum contract</h3>
                    <p class="trust-desc-dark">Sistem kerja bulanan. Anda bebas memutuskan untuk lanjut atau berhenti setiap saat — tidak ada kontrak 6-12 bulan yang lazim diterapkan oleh kebanyakan agency lain.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== TESTIMONIALS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Studi Kasus & Testimoni
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Pengalaman mereka yang telah<br/>
                    <span class="text-accent">bekerja sama dengan Tim Beriklan.</span>
                </h2>
            </div>

            <div class="grid md:grid-cols-3 gap-5 max-w-6xl mx-auto reveal-stagger">
