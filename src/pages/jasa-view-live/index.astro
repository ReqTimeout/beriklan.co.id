import RelatedServices from '../../components/RelatedServices.svelte';
import FeatureGrid from '../../components/FeatureGrid.svelte';
import StepGrid from '../../components/StepGrid.svelte';
import Footer from '../../components/Footer.svelte';
import { MessageCircle, ArrowRight, Radio, Sparkles, Target, Zap, Users, Shield, Database, Clock, Tv, Cast, TrendingUp, Check, Smartphone, Globe } from 'lucide-svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20tertarik%20dengan%20jasa%20view%20live%20untuk%20live%20streaming.%20Mohon%20info%20paket%20dan%20harga.";

