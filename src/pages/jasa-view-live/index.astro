        priceLabel: '12.000',
        duration: '20 viewers / 1 jam live',
        tagline: 'Cocok untuk live pendek, tes, atau warming up sebelum live utama.',
        features: [
            '20 viewers real aktif masuk gradual',
            'Durasi sampai 1 jam live',
            'Multi-platform (TikTok, Shopee, YouTube, IG, Twitch)',
            'Cocok untuk live pendek atau tes',
            'Tanpa risiko untuk akun Anda',
        ],
        priceNote: 'harga per sesi live',
        disclaimer: 'Viewers masuk dalam 5-15 menit setelah order.',
    },
    {
        name: 'Starter',
        priceLabel: '25.000',
        duration: '50 viewers / 1 jam live',
        tagline: 'Untuk live rutin yang butuh boost awal biar algoritma notice Anda.',
        features: [
            '50 viewers real aktif',
            'Durasi sampai 1 jam live',
            'Multi-platform (semua channel)',
            'Cocok untuk seller & streamer pemula',
            'Star Pick — paket paling sering dipilih',
        ],
