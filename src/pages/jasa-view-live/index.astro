        disclaimer: 'Bonus paket mingguan/bulanan: diskon 10-15%.',
        highlight: true,
    },
    {
        name: 'Basic',
        priceLabel: '45.000',
        duration: '100 viewers / 1 jam live',
        tagline: 'Sweet spot untuk seller Shopee Live yang mau boost ranking.',
        features: [
            '100 viewers real aktif stay selama live',
            'Durasi sampai 1 jam live',
            'Multi-platform (semua channel)',
            'Cocok untuk seller Shopee / TikTok Shop',
            'Real account, no bot — aman untuk akun',
        ],
        priceNote: 'Rp 450/viewer/jam',
        disclaimer: 'Cocok untuk live mingguan / konsistensi algorithm boost.',
    },
    {
        name: 'Pro',
        priceLabel: '80.000',
        duration: '200 viewers / 1 jam live',
        tagline: 'Untuk yang serius push conversion dan product placement.',
        features: [
            '200 viewers real aktif',
            'Durasi sampai 1 jam live',
            'Multi-platform semua channel',
            'Cocok untuk launching produk & event',
            'Boost organic distribution algorithm',
        ],
        priceNote: 'Rp 400/viewer/jam',
        disclaimer: 'Repeat order diskon khusus.',
    },
    {
        name: 'Bisnis',
        priceLabel: '115.000',
        duration: '300 viewers / 1 jam live',
        tagline: 'Untuk brand dan toko yang live commerce setiap hari.',
        features: [
            '300 viewers real aktif',
            'Durasi sampai 1 jam live',
            'Multi-platform semua channel',
            'Cocok untuk brand rutin live commerce',
            'Support prioritas + dedicated account manager',
        ],
        priceNote: 'Rp 383/viewer/jam',
        disclaimer: 'Cocok untuk paket mingguan dengan jadwal tetap.',
    },
    {
        name: 'Premium',
        priceLabel: '175.000',
        duration: '500 viewers / 1 jam live',
        tagline: 'Untuk event launching besar atau live dengan target viewers tinggi.',
        features: [
            '500 viewers real aktif',
            'Durasi sampai 1 jam live',
            'Multi-platform semua channel',
            'Cocok untuk launching / event korporat',
            'Support 24/7 + flexible reschedule',
        ],
        priceNote: 'Rp 350/viewer/jam',
        disclaimer: 'Untuk >500 viewers atau paket bulanan, custom price.',
    },
];

const features = [
    { iconName: 'Sparkles', title: 'Real Account, No Bot', desc: 'Viewer dari kami adalah akun aktif — bukan automation bot. Behavior manusiawi, interaksi natural, no flag dari platform.' },
    { iconName: 'Users', title: 'Boost Algorithm Organik', desc: 'Platform (TikTok, Shopee, YouTube, IG, Twitch) memprioritaskan live dengan viewers aktif — boost eksposur sampai 3-5x lebih luas dari biasanya.' },
    { iconName: 'TrendingUp', title: 'Masuk Gradual 5-15 Menit', desc: 'Viewers tidak muncul tiba-tiba. Mereka join gradual sejak menit pertama — bikin live Anda kelihatan organik dan trending di For You / Explore.' },
    { iconName: 'Shield', title: 'Aman untuk Akun Anda', desc: 'Viewers tidak like/comment spam yang trigger flag platform. Tidak ada aktivitas dari akun Anda — kami handle dari sisi viewer. Sudah dipakai 1.200+ seller tanpa satu pun kena masalah.' },
    { iconName: 'Smartphone', title: 'Multi-Platform Sekaligus', desc: 'Satu order, lima platform. Live TikTok + Shopee + YouTube + Instagram + Twitch — semua boost viewers bersamaan.' },
    { iconName: 'Clock', title: 'Start dalam 5 Menit', desc: 'Setelah order dikonfirmasi, viewers mulai masuk. Tidak perlu rekam dulu — kalau live Anda sudah jalan, kami ikut real-time.' },
];

const steps = [
    { num: '01', tag: 'HARI H', title: 'Kirim Detail Live', desc: 'Share username/platform/tanggal/jam mulai ke tim kami via WhatsApp. Order dikonfirmasi max 30 menit setelah detail lengkap.' },
    { num: '02', tag: 'HARI H', title: 'Pembayaran & Persiapan', desc: 'Transfer via QRIS/e-wallet. Invoice langsung dikirim. Untuk paket besar, DP 50% dimungkinkan.' },
    { num: '03', tag: 'LIVE', title: 'Viewers Bergabung', desc: 'Saat live Anda mulai, viewers kami join gradual dalam 5-15 menit. Tidak tiba-tiba, tidak mencurigakan — terlihat natural.' },
    { num: '04', tag: 'POST-LIVE', title: 'Evaluasi & Recurrence', desc: 'Setelah live selesai, kami bisa evaluasi performa. Mau jadwal rutin Selasa-Jumat? Kami bisa kasih diskon 10-15% untuk paket berulang.' },
];

const faqs = [
    { q: 'Apakah viewer-nya bot atau akun asli?', a: 'Akun asli, no automation. Mereka adalah user aktif platform yang stay sesuai durasi live. Interaksi mereka natural dan manusiawi — tidak ada like/comment spam yang bisa trigger flag.' },
    { q: 'Apakah aman untuk akun saya?', a: 'Sangat aman. Viewers dari kami tidak berinteraksi aneh dari akun Anda — semua aktivitas berasal dari viewer, bukan akun Anda. Sudah dipakai 1.200+ seller dan streamer tanpa satu pun akun kena masalah.' },
    { q: 'Berapa lama viewers muncul setelah order?', a: '5-15 menit setelah live Anda mulai. Tidak langsung muncul tiba-tiba — gradual seperti live normal pada umumnya.' },
    { q: 'Platform apa saja yang didukung?', a: 'TikTok Live, Shopee Live, YouTube Live, Instagram Live, Twitch, Lazada Live. Platform lain yang support live streaming juga bisa — chat dulu saja untuk konfirmasi.' },
    { q: 'Bisakah order untuk viewer lebih dari 500 atau paket bulanan?', a: 'Bisa. Untuk 500+ viewers atau paket mingguan/bulanan dengan jadwal tetap, kita ngobrol dulu via WA untuk dapat harga terbaik. Recurring schedule (misal: tiap Selasa & Jumat) bisa dapet diskon tambahan 10-15%.' },
    { q: 'Apa yang terjadi kalau viewers drop sebelum durasi selesai?', a: 'Kalau viewers drop karena force majeure atau platform issue, kami refund pro-rata atau replace viewers di sesi berikutnya. Yang penting komunikasi dulu — kami komunikatif, bukan template bot.' },
    { q: 'Apakah ada minimum durasi live?', a: 'Order 1 sesi = viewers masuk untuk 1 jam durasi live. Untuk live lebih panjang, bisa dihitung sebagai multiple sesi atau paket khusus.' },
];

const relatedItems = [
    { icon: '📱', label: 'Jasa Iklan TikTok', desc: 'Untuk live TikTok yang sudah berjalan dan butuh paid traffic tambahan.', href: '/jasa-iklan-tiktok' },
    { icon: '🛍️', label: 'Kelola Instagram', desc: 'Manajemen konten Instagram rutin untuk omni-channel marketing.', href: '/jasa-kelola-instagram' },
    { icon: '🎬', label: 'Jasa Iklan YouTube', desc: 'Untuk YouTube Ads yang menyasar viewers berdedikasi.', href: '/jasa-iklan-youtube' },
];

const categoryLabels = {
    'meta': 'Facebook & Instagram',
    'tiktok': 'TikTok',
    'google': 'Google Ads',
    'youtube': 'YouTube',
    'strategy': 'Strategi',
    'case-study': 'Studi Kasus',
};
---

<Layout title="Jasa View Live Multi-Platform | Boost Viewers Live Streaming — Beriklan" description="Boost viewers live streaming untuk TikTok, Shopee, YouTube, Instagram, Twitch. Real account, no bot, aman untuk akun Anda. Mulai Rp 12.000 untuk 20 viewers.">

    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <!-- ====================== HERO ====================== -->
    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-24 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="abs-blob abs-blob-1"></div>
        <div class="abs-blob abs-blob-2"></div>

        <svg class="absolute left-1/2 -translate-x-1/2 top-32 w-40 h-12 opacity-30 hidden lg:block" viewBox="0 0 160 40" aria-hidden="true">
            <path d="M5,20 Q40,5 80,20 T155,20" stroke="#0f1e3d" stroke-width="1.5" fill="none" stroke-dasharray="3 5"/>
        </svg>

        <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
            <div class="space-y-7 text-center lg:text-left">
                <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
                    </span>
                    <Radio class="w-3 h-3" />
                    <span class="opacity-0 anim-fade-in">Jasa View Live · TikTok, Shopee, YouTube, IG, Twitch</span>
                </div>

                <h1 class="hero-h1 font-display font-extrabold text-4xl md:text-5xl lg:text-[2.6rem] xl:text-[2.9rem] text-ink leading-[1.05] tracking-tight">
                    <span class="anim-fade-up">Live Sepi,</span><br/>
                    <span class="anim-fade-up text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent" style="animation-delay: 80ms;">Algoritma Tidak Mau Angkat</span><br/>
                    <span class="anim-fade-up" style="animation-delay: 160ms;">— Kami Solusinya.</span>
                </h1>

                <p class="hero-sub text-base md:text-lg text-muted leading-relaxed max-w-xl mx-auto lg:mx-0 anim-fade-up" style="animation-delay: 240ms;">
                    Algorithm TikTok, Shopee Live, YouTube Live — semuanya satu prinsip: live yang ramai naik. Viewer riil dari kami masuk gradual sejak menit pertama, bikin live Anda kelihatan trending — tanpa flag, tanpa bot, tanpa risiko untuk akun Anda.
                </p>

                <div class="hero-ctas flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2 anim-fade-up" style="animation-delay: 320ms;">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-ink text-white px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine">
                        <span class="relative z-10 flex items-center gap-2">
                            Order Viewers Live
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 group-hover:rotate-12 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                    </a>
                    <a href="#pricing" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full font-bold text-ink border border-gray-200 bg-white hover:border-ink hover:-translate-y-0.5 transition-all">
                        Lihat Paket & Harga
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </a>
                </div>

                <div class="hero-trust pt-6 border-t border-gray-200/60 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-xs md:text-sm reveal" style="transition-delay: 200ms;">
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted"><strong class="text-ink">Mulai Rp 12.000</strong> untuk 20 viewers</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Real account, <strong class="text-ink">no bot</strong></span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Aman untuk akun Anda</span></div>
                </div>
            </div>

            <div class="relative flex justify-center lg:justify-end anim-fade-up" style="animation-delay: 400ms;">
                <!-- Live streaming preview -->
                <div class="relative w-full max-w-md mx-auto">
                    <div class="rounded-3xl overflow-hidden bg-gradient-to-br from-primary-2 to-ink border-4 border-white shadow-2xl aspect-[9/16] max-h-[560px] relative">
                        <!-- Top bar: TikTok style -->
                        <div class="absolute top-0 left-0 right-0 p-3 flex items-center gap-2 bg-gradient-to-b from-ink/80 to-transparent z-10">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-500 to-accent flex items-center justify-center text-white text-xs font-bold">@</div>
                            <div class="flex-1">
                                <p class="text-white text-xs font-bold">@brand_kamu</p>
                                <p class="text-white/70 text-[10px] flex items-center gap-1">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                    LIVE
                                </p>
                            </div>
                            <div class="px-2 py-1 bg-red-500 text-white text-[10px] font-bold rounded-full uppercase tracking-wider">Live</div>
                        </div>
                        <!-- Viewer count -->
                        <div class="absolute top-12 right-3 z-10 px-2 py-1 bg-white/15 backdrop-blur-md rounded-full text-white text-[10px] font-bold flex items-center gap-1">
                            <Users class="w-3 h-3" />
                            <span>500 viewers</span>
                        </div>
                        <!-- Chat overlay -->
                        <div class="absolute bottom-12 left-3 right-3 space-y-1.5 z-10 max-h-32 overflow-hidden">
                            <div class="flex items-start gap-1.5">
                                <span class="px-1.5 py-0.5 bg-white/20 backdrop-blur-sm text-white text-[10px] font-bold rounded">User1</span>
                                <span class="text-white text-[11px] drop-shadow">keren banget live nya 🔥</span>
                            </div>
                            <div class="flex items-start gap-1.5">
                                <span class="px-1.5 py-0.5 bg-white/20 backdrop-blur-sm text-white text-[10px] font-bold rounded">User2</span>
                                <span class="text-white text-[11px] drop-shadow">mau dong diskonnya</span>
                            </div>
                            <div class="flex items-start gap-1.5">
                                <span class="px-1.5 py-0.5 bg-white/20 backdrop-blur-sm text-white text-[10px] font-bold rounded">User3</span>
                                <span class="text-white text-[11px] drop-shadow">stok masih ada ga kak?</span>
                            </div>
                        </div>
                        <!-- Bottom CTA -->
                        <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-ink/90 to-transparent">
                            <div class="bg-accent text-ink text-center py-2 rounded-full text-xs font-bold">BELI SEKARANG</div>
                        </div>
                        <!-- Product overlay -->
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <div class="w-32 h-32 rounded-2xl bg-gradient-to-br from-accent/30 to-pink-500/30 backdrop-blur-sm border-2 border-white/40 flex items-center justify-center">
                                <div class="text-center">
                                    <p class="text-white text-[10px] font-bold uppercase tracking-wider">Featured</p>
                                    <p class="text-white text-base font-bold">Product</p>
                                    <p class="text-accent text-sm font-extrabold">Rp 99K</p>
                                </div>
                            </div>
                        </div>
                        <!-- Live badge -->
                        <div class="absolute top-12 left-3 z-10">
                            <div class="flex items-center gap-1.5 bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded-full">
                                <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
                                LIVE NOW
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- ====================== TRUST BAR ====================== -->
    <section class="py-7 bg-ink border-y border-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
                <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.18em] text-white/40">Cocok untuk semua platform live</p>
                <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-white/70 text-sm font-semibold trust-word">
                    <span>TikTok Live</span><span class="text-white/30">·</span>
                    <span>Shopee Live</span><span class="text-white/30">·</span>
                    <span>YouTube Live</span><span class="text-white/30">·</span>
                    <span>Instagram Live</span><span class="text-white/30">·</span>
                    <span>Twitch</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== WHY FACEBOOK ADS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Kenapa View Live Penting
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Live sepi = algoritma mengabaikan Anda.<br/>
                    <span class="text-accent">Tapi kami tahu cara membalikkannya.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    Semua platform live — TikTok, Shopee, YouTube, Instagram, Twitch — punya satu kesamaan: mereka memprioritaskan live dengan viewers aktif. Live dengan 500 viewers naik 5x lebih sering di For You / Explore dibanding live dengan 50 viewers. Kami bantu Anda memulai momentum itu.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="why-card group">
                    <div class="why-icon">
                        <Sparkles class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">Algorithm Boost</h3>
                    <p class="why-desc">Platform memprioritaskan live dengan viewers aktif. Boost viewers = boost distribusi organik sampai 5x lebih luas dari biasanya.</p>
                </div>
                <div class="why-card group" style="animation-delay: 100ms;">
                    <div class="why-icon">
                        <Shield class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">100% Aman</h3>
                    <p class="why-desc">Viewers dari kami akun riil, bukan bot automation. Tidak ada aktivitas dari akun Anda — sudah dipakai 1.200+ seller tanpa satu pun kena masalah.</p>
                </div>
                <div class="why-card group" style="animation-delay: 200ms;">
                    <div class="why-icon">
                        <Globe class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">Multi-Platform</h3>
                    <p class="why-desc">Satu order = boost di TikTok, Shopee, YouTube, Instagram, Twitch sekaligus. Hemat waktu dan biaya dibanding order terpisah.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== FEATURES GRID ====================== -->
    <section id="fitur" class="py-20 md:py-28 bg-soft relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    6 Keunggulan Layanan
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Kenapa layanan kami berbeda<br/>
                    <span class="text-accent">dari viewer bot pada umumnya.</span>
                </h2>
            </div>

            <FeatureGrid items={features} client:visible />
        </div>
    </section>

    <!-- ====================== HOW IT WORKS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(15,30,61,0.05) 1px, transparent 0); background-size: 32px 32px;"></div>

        <div class="container mx-auto px-6 relative">
            <div class="max-w-2xl mx-auto text-center mb-14 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-6 h-px bg-accent"></span>
                    Cara Kerja
                    <span class="w-6 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Dari order sampai live naik,<br/>
                    <span class="text-accent">kurang dari 30 menit.</span>
                </h2>
            </div>

            <StepGrid items={steps} client:visible />
        </div>
    </section>

    <!-- ====================== PRICING ====================== -->
    <section id="pricing" class="py-20 md:py-28 bg-gradient-to-br from-soft via-white to-beige relative overflow-hidden">
        <div class="abs-blob abs-blob-3"></div>
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Paket & Harga
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Enam paket, dari pemanasan<br/>
                    <span class="text-accent">sampai launching akbar.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    Semua paket sudah termasuk viewers riil (bukan bot), gradual entry, dan support via WhatsApp. Untuk paket mingguan/bulanan atau viewer 500+, chat dulu untuk harga khusus.
