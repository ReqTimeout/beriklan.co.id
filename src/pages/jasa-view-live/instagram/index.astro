---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.svelte';
import StickyCTA from '../../../components/StickyCTA.svelte';
import PricingCards from '../../../components/PricingCards.svelte';
import FaqAccordion from '../../../components/FaqAccordion.svelte';
import RelatedServices from '../../../components/RelatedServices.svelte';
import FeatureGrid from '../../../components/FeatureGrid.svelte';
import StepGrid from '../../../components/StepGrid.svelte';
import Footer from '../../../components/Footer.svelte';
import { MessageCircle, ArrowRight, Radio, Sparkles, Users, Shield, Clock, TrendingUp, Check, Smartphone, Tv, Video, Heart, Zap, Camera, MessageCircle as MessageCircleIcon } from 'lucide-svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20tertarik%20dengan%20jasa%20view%20live%20Instagram.%20Mohon%20info%20paket%20dan%20harga.";

const tiers = [
    { name: 'Pemanasan', priceLabel: '12.000', duration: '20 viewers / 1 jam', tagline: 'Untuk warming up IG Live sebelum launching.', features: ['20 viewers riil', 'Multi-platform', 'Tanpa risiko', 'Cocok untuk live pendek', 'Support WhatsApp'], priceNote: 'per sesi', disclaimer: 'Viewers real IG account.' },
    { name: 'Starter', priceLabel: '25.000', duration: '50 viewers / 1 jam', tagline: 'Untuk IG Live brand yang boost reach & engagement.', features: ['50 viewers riil', 'Boost IG reach', 'Multi-platform', 'Real IG account', 'Support WhatsApp'], priceNote: 'Rp 500/viewer', highlight: true, disclaimer: 'Paling laris brand.' },
    { name: 'Basic', priceLabel: '45.000', duration: '100 viewers / 1 jam', tagline: 'Untuk IG Live rutin creator & brand.', features: ['100 viewers riil', 'Boost IG reach', 'Cocok untuk daily live', 'Multi-platform', 'Tanpa risiko'], priceNote: 'Rp 450/viewer', disclaimer: 'Paling sering dipilih.' },
    { name: 'Pro', priceLabel: '80.000', duration: '200 viewers / 1 jam', tagline: 'Untuk launching produk / event IG Live.', features: ['200 viewers riil', 'Boost IG Stories', 'Multi-platform', 'Cocok untuk launching', 'Support prioritas'], priceNote: 'Rp 400/viewer', disclaimer: 'Recurring diskon 10%.' },
    { name: 'Bisnis', priceLabel: '115.000', duration: '300 viewers / 1 jam', tagline: 'Untuk brand IG rutin dengan live commerce.', features: ['300 viewers riil', 'Cocok untuk IG Shopping', 'Multi-platform', 'Support account manager', 'Laporan mingguan'], priceNote: 'Rp 383/viewer', disclaimer: 'Cocok untuk paket mingguan.' },
    { name: 'Premium', priceLabel: '175.000', duration: '500 viewers / 1 jam', tagline: 'Untuk launching event IG Live premium.', features: ['500 viewers riil', 'Multi-platform', 'Cocok untuk launching premium', 'Support 24/7', 'Flexible reschedule'], priceNote: 'Rp 350/viewer', disclaimer: 'Untuk >500, custom.' },
];

const features = [
    { iconName: 'Sparkles', title: 'Boost IG Reach', desc: 'Instagram merekomendasikan live dengan viewers aktif. Boost viewers = boost reach di Explore & Reels.' },
    { iconName: 'Users', title: 'Real Account IG', desc: 'Viewers dari kami akun Instagram aktif. Stay, react, dan share ke Story natural.' },
    { iconName: 'TrendingUp', title: 'Masuk Gradual 5-15 Menit', desc: 'Viewers join gradual sejak menit pertama. IG algorithm notice live Anda sebagai live yang sedang trending.' },
    { iconName: 'Shield', title: 'Aman untuk Akun IG', desc: 'Viewers tidak like spam. Tidak ada aktivitas dari akun Anda. 1.200+ live IG tanpa masalah.' },
    { iconName: 'Heart', title: 'Masuk IG Live + Lainnya', desc: 'Order untuk IG Live, viewers juga bisa stay di platform lain yang sedang live bersamaan.' },
    { iconName: 'Clock', title: 'Start dalam 5 Menit', desc: 'IG Live Anda yang sudah jalan? Kami ikut real-time. Tidak perlu rekam ulang.' },
];

const steps = [
    { num: '01', tag: 'HARI H', title: 'Kirim Detail Live IG', desc: 'Share username IG + tanggal/jam mulai live. Order dikonfirmasi max 30 menit.' },
    { num: '02', tag: 'HARI H', title: 'Pembayaran', desc: 'Transfer via QRIS/e-wallet. Invoice langsung. DP 50% untuk paket besar.' },
    { num: '03', tag: 'LIVE', title: 'Viewers Join', desc: 'Saat IG Live Anda mulai, viewers join gradual 5-15 menit. IG algorithm notice live Anda.' },
    { num: '04', tag: 'POST-LIVE', title: 'Evaluasi', desc: 'Setelah live, kami evaluasi performa reach. Recurring 2-3x seminggu diskon 10-15%.' },
];

const faqs = [
    { q: 'Apakah viewers-nya bot atau akun asli Instagram?', a: 'Akun asli Instagram, no automation. Mereka user aktif yang stay sesuai durasi live. Interaksi natural.' },
    { q: 'Apakah aman untuk akun IG saya?', a: 'Sangat aman. Viewers tidak like spam. Tidak ada aktivitas dari akun Anda. 1.200+ live IG tanpa masalah.' },
    { q: 'Berapa lama viewers muncul setelah IG Live mulai?', a: '5-15 menit setelah live dimulai. Gradual seperti IG Live normal.' },
    { q: 'Apakah membantu algoritma IG?', a: 'Ya. IG memprioritaskan live dengan viewers aktif. Boost viewers = boost reach di Explore & Reels.' },
    { q: 'Bisa order untuk viewers lebih dari 500 atau paket harian?', a: 'Bisa. Untuk 500+ viewers atau paket harian/mingguan, chat dulu via WA. Recurring diskon 10-15%.' },
    { q: 'Apakah viewers stay selama durasi IG Live?', a: 'Ya. Stay sesuai durasi yang Anda pesan. Tidak ada yang tiba-tiba pergi.' },
    { q: 'Bagaimana jika IG memberi flag setelah order?', a: 'Belum pernah terjadi. Viewers interaksi natural. Tidak ada pattern bot.' },
];

const relatedItems = [
    { icon: '📱', label: 'Jasa View Live TikTok', desc: 'Untuk live TikTok yang fokus ke FYP algorithm.', href: '/jasa-view-live/tiktok' },
    { icon: '🎬', label: 'Jasa View Live YouTube', desc: 'Untuk channel YouTube yang boost watch time.', href: '/jasa-view-live/youtube' },
    { icon: '📡', label: 'Jasa View Live Multi-Platform', desc: 'Satu order, semua platform live.', href: '/jasa-view-live' },
];
---

<Layout title="Jasa View Live Instagram | Boost IG Reach & Engagement — Beriklan" description="Boost viewers live Instagram agar reach & engagement naik. Real account IG, no bot, aman. Mulai Rp 12.000 untuk 20 viewers." canonical="https://beriklan.co.id/jasa-view-live/instagram/">
    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-24 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="abs-blob abs-blob-1"></div>
        <div class="abs-blob abs-blob-2"></div>
        <svg class="absolute left-1/2 -translate-x-1/2 top-32 w-40 h-12 opacity-30 hidden lg:block" viewBox="0 0 160 40" aria-hidden="true"><path d="M5,20 Q40,5 80,20 T155,20" stroke="#0f1e3d" stroke-width="1.5" fill="none" stroke-dasharray="3 5"/></svg>
        <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
            <div class="space-y-7 text-center lg:text-left">
                <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm">
                    <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span></span>
                    <span class="opacity-0 anim-fade-in">Jasa View Live Instagram · Boost IG Reach</span>
                </div>
                <h1 class="hero-h1 font-display font-extrabold text-4xl md:text-5xl lg:text-[2.6rem] xl:text-[2.9rem] text-ink leading-[1.05] tracking-tight">
                    <span class="anim-fade-up">Live IG Sepi,</span><br/>
                    <span class="anim-fade-up text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent" style="animation-delay: 80ms;">Reach Tidak Naik.</span><br/>
                    <span class="anim-fade-up" style="animation-delay: 160ms;">— Algorithm Butuh Viewers.</span>
                </h1>
                <p class="hero-sub text-base md:text-lg text-muted leading-relaxed max-w-xl mx-auto lg:mx-0 anim-fade-up" style="animation-delay: 240ms;">
                    Instagram merekomendasikan live berdasarkan jumlah viewers & engagement. Lebih banyak viewers aktif = lebih sering muncul di Explore & Reels. Viewer riil dari kami join gradual 5-15 menit, meningkatkan reach live Anda, tanpa flag, tanpa bot, tanpa risiko untuk akun IG.
                </p>
                <div class="hero-ctas flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2 anim-fade-up" style="animation-delay: 320ms;">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-ink text-white px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine">
                        <span class="relative z-10 flex items-center gap-2">Order Viewers Instagram<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 group-hover:rotate-12 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
                    </a>
                    <a href="#pricing" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full font-bold text-ink border border-gray-200 bg-white hover:border-ink hover:-translate-y-0.5 transition-all">Lihat Paket & Harga<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></a>
                </div>
                <div class="hero-trust pt-6 border-t border-gray-200/60 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-xs md:text-sm reveal" style="transition-delay: 200ms;">
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted"><strong class="text-ink">Mulai Rp 12.000</strong> untuk 20 viewers</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Real account, <strong class="text-ink">no bot</strong></span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Boost IG reach & Reels</span></div>
                </div>
            </div>
            <div class="relative flex justify-center lg:justify-end anim-fade-up" style="animation-delay: 400ms;">
                <div class="relative w-full max-w-md mx-auto">
                    <div class="rounded-3xl overflow-hidden bg-gradient-to-br from-pink-500 via-purple-500 to-orange-500 border-4 border-white shadow-2xl aspect-[9/16] max-h-[560px] relative">
                        <div class="absolute top-0 left-0 right-0 p-3 flex items-center gap-2 bg-gradient-to-b from-black/80 to-transparent z-10">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-500 to-purple-500 flex items-center justify-center text-white text-xs font-bold">@</div>
                            <div class="flex-1"><p class="text-white text-xs font-bold">@brand_ig</p><p class="text-white/70 text-[10px] flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-pink-500 animate-pulse"></span>LIVE · 500 watching</p></div>
                            <div class="px-2 py-1 bg-pink-500 text-white text-[10px] font-bold rounded-full uppercase tracking-wider">IG</div>
                        </div>
                        <div class="absolute top-12 right-3 z-10 px-2 py-1 bg-white/15 backdrop-blur-md rounded-full text-white text-[10px] font-bold flex items-center gap-1"><Users class="w-3 h-3" /><span>200 viewers</span></div>
                        <div class="absolute top-12 left-3 z-10"><div class="flex items-center gap-1.5 bg-pink-500 text-white text-[10px] font-bold px-2 py-1 rounded-full"><span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>LIVE NOW</div></div>
                        <div class="absolute bottom-12 left-3 right-3 space-y-1.5 z-10 max-h-32 overflow-hidden">
                            <div class="flex items-start gap-1.5"><span class="px-1.5 py-0.5 bg-pink-500/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user1</span><span class="text-white text-[11px] drop-shadow">live IG mantap! 💜</span></div>
                            <div class="flex items-start gap-1.5"><span class="px-1.5 py-0.5 bg-pink-500/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user2</span><span class="text-white text-[11px] drop-shadow">reels cocok ga kak?</span></div>
                            <div class="flex items-start gap-1.5"><span class="px-1.5 py-0.5 bg-pink-500/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user3</span><span class="text-white text-[11px] drop-shadow">diskonn berapa kak?</span></div>
                        </div>
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none"><div class="w-32 h-32 rounded-2xl bg-gradient-to-br from-pink-500/40 to-purple-500/40 backdrop-blur-sm border-2 border-white/40 flex items-center justify-center"><div class="text-center"><p class="text-white text-[10px] font-bold uppercase tracking-wider">IG Live</p><p class="text-white text-base font-bold">Shopping</p><p class="text-pink-300 text-sm font-extrabold">Rp 99K</p></div></div></div>
                        <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/95 to-transparent"><div class="bg-gradient-to-r from-pink-500 to-purple-500 text-white text-center py-2 rounded-full text-xs font-bold">BELI SEKARANG</div></div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="py-7 bg-ink border-y border-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
                <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.18em] text-white/40">Optimal untuk Instagram</p>
                <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-white/70 text-sm font-semibold">
                    <span>IG Reach</span><span class="text-white/30">·</span><span>Reels & Explore</span><span class="text-white/30">·</span><span>IG Shopping</span><span class="text-white/30">·</span><span>Story Share</span>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent"><span class="w-8 h-px bg-accent"></span>Kenapa View Live Instagram<span class="w-8 h-px bg-accent"></span></p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">Instagram algorithm satu hal:<br/><span class="text-accent">banyak viewers = reach lebih luas.</span></h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">IG memprioritaskan live dengan viewers aktif. Live dengan 100+ viewers muncul 4x lebih sering di Explore & Reels dibanding live sepi.</p>
            </div>
            <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="why-card group"><div class="why-icon"><Sparkles class="w-6 h-6" strokeWidth="2.2" /></div><h3 class="why-title">Boost IG Reach</h3><p class="why-desc">Instagram merekomendasikan live dengan viewers aktif. Boost viewers = boost reach di Explore & Reels.</p></div>
                <div class="why-card group" style="animation-delay: 100ms;"><div class="why-icon"><Shield class="w-6 h-6" strokeWidth="2.2" /></div><h3 class="why-title">Aman untuk Akun</h3><p class="why-desc">Viewers dari kami akun IG aktif. Tidak like spam. Tidak ada aktivitas dari akun Anda. 1.200+ live IG tanpa masalah.</p></div>
                <div class="why-card group" style="animation-delay: 200ms;"><div class="why-icon"><Heart class="w-6 h-6" strokeWidth="2.2" fill="currentColor" /></div><h3 class="why-title">Cocok untuk IG Shopping</h3><p class="why-desc">Viewers aktif lihat produk lebih lama, share ke Story otomatis, conversion naik signifikan dari live biasa.</p></div>
            </div>
        </div>
    </section>

    <section id="fitur" class="py-20 md:py-28 bg-soft relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent"><span class="w-8 h-px bg-accent"></span>6 Keunggulan<span class="w-8 h-px bg-accent"></span></p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">Kenapa layanan kami berbeda<br/><span class="text-accent">dari viewer bot biasa.</span></h2>
            </div>
            <FeatureGrid items={features} client:visible />
        </div>
    </section>

    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(15,30,61,0.05) 1px, transparent 0); background-size: 32px 32px;"></div>
        <div class="container mx-auto px-6 relative">
            <div class="max-w-2xl mx-auto text-center mb-14 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent"><span class="w-6 h-px bg-accent"></span>Cara Kerja<span class="w-6 h-px bg-accent"></span></p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">Dari order sampai trending,<br/><span class="text-accent">kurang dari 30 menit.</span></h2>
            </div>
            <StepGrid items={steps} client:visible />
        </div>
    </section>

    <section id="pricing" class="py-20 md:py-28 bg-gradient-to-br from-soft via-white to-beige relative overflow-hidden">
        <div class="abs-blob abs-blob-3"></div>
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent"><span class="w-8 h-px bg-accent"></span>Paket & Harga<span class="w-8 h-px bg-accent"></span></p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">Enam paket, dari pemanasan<br/><span class="text-accent">sampai launching akbar.</span></h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">Semua paket sudah termasuk viewers riil, gradual entry, dan support via WhatsApp. Untuk paket mingguan/bulanan atau viewer 500+, chat dulu untuk harga khusus.</p>
            </div>
            <PricingCards tiers={tiers} pageSlug="View Live Instagram" highlightIndex={1} columns={3} client:only="svelte" />
            <div class="mt-10 max-w-2xl mx-auto reveal"><div class="bg-white rounded-2xl border border-gray-100 p-5 md:p-6 shadow-soft"><div class="flex items-start gap-3"><div class="w-10 h-10 rounded-xl bg-accent/15 flex items-center justify-center shrink-0"><Check class="w-5 h-5 text-accent" strokeWidth="2.5" /></div><div><p class="font-display font-bold text-base text-ink mb-1">Butuh paket harian atau launching event?</p><p class="text-sm text-muted leading-relaxed">Sesi konsultasi 15 menit gratis. Kami bantu pilih paket yang paling cocok dengan jadwal live dan target reach Anda.</p><a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 mt-3 text-sm font-bold text-accent hover:text-ink transition-colors group">Chat via WhatsApp<ArrowRight class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" /></a></div></div></div></div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-ink text-white relative overflow-hidden">
        <div class="abs-radaial-1"></div><div class="stat-orb stat-orb-1"></div><div class="stat-orb stat-orb-2"></div>
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent"><span class="w-8 h-px bg-accent"></span>Bukti Nyata<span class="w-8 h-px bg-accent"></span></p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-white leading-[1.1] tracking-tight mt-3">Sudah 1.200+ akun IG<br/><span class="text-accent">pakai layanan ini.</span></h2>
            </div>
            <div class="grid md:grid-cols-4 gap-4 max-w-5xl mx-auto reveal-stagger">
                <div class="stat-card"><div class="stat-num">4x</div><div class="stat-label">Boost IG reach</div><div class="stat-bar"><span style="width: 80%"></span></div><p class="stat-foot">rata-rata Explore</p></div>
                <div class="stat-card" style="animation-delay: 80ms;"><div class="stat-num">0</div><div class="stat-label">Akun kena flag</div><div class="stat-bar"><span style="width: 5%"></span></div><p class="stat-foot">sepanjang penggunaan</p></div>
                <div class="stat-card" style="animation-delay: 160ms;"><div class="stat-num">3x</div><div class="stat-label">Engagement boost</div><div class="stat-bar"><span style="width: 70%"></span></div><p class="stat-foot">rata-rata IG live</p></div>
                <div class="stat-card" style="animation-delay: 240ms;"><div class="stat-num">15%</div><div class="stat-label">Diskon rutin</div><div class="stat-bar"><span style="width: 100%"></span></div><p class="stat-foot">paket mingguan</p></div>
            </div>
        </div>
    </section>

    <section id="faq" class="py-20 md:py-28 bg-soft relative overflow-hidden">
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent"><span class="w-8 h-px bg-accent"></span>Sebelum order<span class="w-8 h-px bg-accent"></span></p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">Pertanyaan tentang<br/><span class="text-accent">live Instagram.</span></h2>
            </div>
            <FaqAccordion items={faqs} client:visible />
        </div>
    </section>

    <RelatedServices items={relatedItems} client:visible />

    <section class="py-20 md:py-28 bg-gradient-to-br from-ink via-primary-2 to-ink text-white relative overflow-hidden">
        <div class="absolute inset-events-none opacity-[0.08] cta-grid" style="pointer-events: none;"></div>
        <div class="abs-radaial-2"></div>
        <div class="floating-emoji emoji-1 hidden lg:flex">📱</div><div class="floating-emoji emoji-2 hidden lg:flex">💜</div><div class="floating-emoji emoji-3 hidden lg:flex">🎬</div>
        <div class="container mx-auto px-6 relative">
