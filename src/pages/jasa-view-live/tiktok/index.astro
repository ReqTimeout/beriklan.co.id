const faqs = [
    { q: 'Apakah viewers-nya bot atau akun asli TikTok?', a: 'Akun asli TikTok, no automation. Mereka user aktif yang stay sesuai durasi live. Interaksi natural, no flag dari TikTok algorithm.' },
    { q: 'Apakah aman untuk akun TikTok saya?', a: 'Sangat aman. Viewers tidak like/comment spam yang bisa trigger shadow ban. Tidak ada aktivitas dari akun Anda. Sudah 1.200+ live TikTok tanpa satu pun kena masalah.' },
    { q: 'Berapa lama viewers muncul setelah live TikTok mulai?', a: '5-15 menit setelah live Anda mulai. Tidak tiba-tiba — gradual seperti live TikTok normal pada umumnya.' },
