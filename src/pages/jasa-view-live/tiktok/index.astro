const relatedItems = [
    { icon: '🛍️', label: 'Jasa View Live Shopee', desc: 'Untuk seller Shopee Live yang fokus ke konversi produk.', href: '/jasa-view-live/shopee' },
    { icon: '📱', label: 'Jasa View Live Instagram', desc: 'Untuk IG Live brand dan creator yang mau boost reach.', href: '/jasa-view-live/instagram' },
    { icon: '🎬', label: 'Jasa View Live Multi-Platform', desc: 'Satu order, semua platform live.', href: '/jasa-view-live' },
];
---

<Layout title="Jasa View Live TikTok | Boost Viewers FYP Algorithm — Beriklan" description="Boost viewers live streaming TikTok agar FYP algorithm notice live Anda. Real account, no bot, aman untuk akun TikTok. Mulai Rp 12.000 untuk 20 viewers." canonical="https://beriklan.co.id/jasa-view-live/tiktok/">

    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-24 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="abs-blob abs-blob-1"></div>
        <div class="abs-blob abs-blob-2"></div>

        <svg class="absolute left-1/2 -translate-x-1/2 top-32 w-40 h-12 opacity-30 hidden lg:block" viewBox="0 0 160 40" aria-hidden="true">
            <path d="M5,20 Q40,5 80,20 T155,20" stroke="#0f1e3d" stroke-width="1.5" fill="none" stroke-dasharray="3 5"/>
        </svg>

        <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
            <div class="space-y-7 text-center lg:text-left">
                <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
                    </span>
                    <span class="opacity-0 anim-fade-in">Jasa View Live TikTok · Boost FYP Algorithm</span>
                </div>

                <h1 class="hero-h1 font-display font-extrabold text-4xl md:text-5xl lg:text-[2.6rem] xl:text-[2.9rem] text-ink leading-[1.05] tracking-tight">
                    <span class="anim-fade-up">Live TikTok Sepi,</span><br/>
                    <span class="anim-fade-up text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent" style="animation-delay: 80ms;">FYP Tidak Mau Angkat.</span><br/>
                    <span class="anim-fade-up" style="animation-delay: 160ms;">— Algoritma Butuh Viewers.</span>
                </h1>

                <p class="hero-sub text-base md:text-lg text-muted leading-relaxed max-w-xl mx-auto lg:mx-0 anim-fade-up" style="animation-delay: 240ms;">
                    TikTok For You Page memprioritaskan live dengan viewers aktif. 100+ viewers = 5x lebih besar jangkauan FYP. Viewer riil dari kami join gradual sejak menit pertama — bikin algoritma TikTok notice live Anda, tanpa flag, tanpa bot, tanpa risiko shadow ban.
                </p>

                <div class="hero-ctas flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2 anim-fade-up" style="animation-delay: 320ms;">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-ink text-white px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine">
                        <span class="relative z-10 flex items-center gap-2">
                            Order Viewers TikTok
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 group-hover:rotate-12 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                    </a>
                    <a href="#pricing" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full font-bold text-ink border border-gray-200 bg-white hover:border-ink hover:-translate-y-0.5 transition-all">
                        Lihat Paket & Harga
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </a>
                </div>

                <div class="hero-trust pt-6 border-t border-gray-200/60 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-xs md:text-sm reveal" style="transition-delay: 200ms;">
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted"><strong class="text-ink">Mulai Rp 12.000</strong> untuk 20 viewers</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Real account, <strong class="text-ink">no bot</strong></span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-muted">Boost FYP algorithm</span></div>
                </div>
            </div>

            <div class="relative flex justify-center lg:justify-end anim-fade-up" style="animation-delay: 400ms;">
                <!-- TikTok Live preview mockup -->
                <div class="relative w-full max-w-md mx-auto">
                    <div class="rounded-3xl overflow-hidden bg-gradient-to-br from-black to-pink-900 border-4 border-white shadow-2xl aspect-[9/16] max-h-[560px] relative">
                        <!-- TikTok top bar -->
                        <div class="absolute top-0 left-0 right-0 p-3 flex items-center gap-2 bg-gradient-to-b from-black/80 to-transparent z-10">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-500 to-cyan-400 flex items-center justify-center text-white text-xs font-bold">@</div>
                            <div class="flex-1">
                                <p class="text-white text-xs font-bold">@brand_tiktok</p>
                                <p class="text-white/70 text-[10px] flex items-center gap-1">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                    LIVE · 1.2K watching
                                </p>
                            </div>
                            <div class="px-2 py-1 bg-pink-500 text-white text-[10px] font-bold rounded-full uppercase tracking-wider">TikTok</div>
                        </div>
                        <!-- TikTok right rail: viewer count -->
                        <div class="absolute top-12 right-3 z-10 px-2 py-1 bg-white/15 backdrop-blur-md rounded-full text-white text-[10px] font-bold flex items-center gap-1">
                            <Users class="w-3 h-3" />
                            <span>200 viewers</span>
                        </div>
                        <!-- Live badge -->
                        <div class="absolute top-12 left-3 z-10">
                            <div class="flex items-center gap-1.5 bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded-full">
                                <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
                                LIVE NOW
                            </div>
                        </div>
                        <!-- TikTok chat overlay -->
                        <div class="absolute bottom-12 left-3 right-3 space-y-1.5 z-10 max-h-32 overflow-hidden">
                            <div class="flex items-start gap-1.5">
                                <span class="px-1.5 py-0.5 bg-pink-500/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user1</span>
                                <span class="text-white text-[11px] drop-shadow">fyp masuk nih 🔥</span>
                            </div>
                            <div class="flex items-start gap-1.5">
                                <span class="px-1.5 py-0.5 bg-cyan-400/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user2</span>
                                <span class="text-white text-[11px] drop-shadow">produk ready ga kak?</span>
                            </div>
                            <div class="flex items-start gap-1.5">
                                <span class="px-1.5 py-0.5 bg-pink-500/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user3</span>
                                <span class="text-white text-[11px] drop-shadow">kak ini diskon berapa?</span>
                            </div>
                        </div>
                        <!-- TikTok product overlay (live shopping) -->
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <div class="w-32 h-32 rounded-2xl bg-gradient-to-br from-pink-500/40 to-cyan-400/40 backdrop-blur-sm border-2 border-white/40 flex items-center justify-center">
                                <div class="text-center">
                                    <p class="text-white text-[10px] font-bold uppercase tracking-wider">Shopping</p>
                                    <p class="text-white text-base font-bold">TikTok Live</p>
                                    <p class="text-pink-300 text-sm font-extrabold">Rp 99K</p>
                                </div>
                            </div>
                        </div>
                        <!-- TikTok CTA cart button -->
                        <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/95 to-transparent">
                            <div class="bg-pink-500 text-white text-center py-2 rounded-full text-xs font-bold flex items-center justify-center gap-1">
                                <Heart class="w-3 h-3" fill="currentColor" />
                                TAP UNTUK BELI
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- ====================== TRUST BAR ====================== -->
    <section class="py-7 bg-ink border-y border-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
                <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.18em] text-white/40">Optimal untuk TikTok</p>
                <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-white/70 text-sm font-semibold trust-word">
                    <span>FYP Algorithm</span><span class="text-white/30">·</span>
                    <span>Live Shopping</span><span class="text-white/30">·</span>
                    <span>TikTok Shop</span><span class="text-white/30">·</span>
                    <span>Real-time Chat</span><span class="text-white/30">·</span>
                    <span>Share & Like</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== WHY TIKTOK ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Kenapa View Live TikTok
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Algoritma FYP TikTok satu hal:<br/>
                    <span class="text-accent">live yang ramai = distribusi luas.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    TikTok For You Page memprioritaskan live dengan viewers aktif. Live dengan 100+ viewers naik 5x lebih sering di FYP dibanding live dengan 20 viewers. Viewer riil dari kami membantu TikTok algorithm notice live Anda — tanpa flag, tanpa shadow ban.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="why-card group">
                    <div class="why-icon">
                        <TrendingUp class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">Boost FYP Algorithm</h3>
                    <p class="why-desc">TikTok memprioritaskan live dengan viewers aktif. Boost viewers = boost distribusi FYP sampai 5x lebih luas dari biasanya.</p>
                </div>
                <div class="why-card group" style="animation-delay: 100ms;">
                    <div class="why-icon">
                        <Shield class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="why-title">Aman dari Shadow Ban</h3>
                    <p class="why-desc">Viewers dari kami interaksi natural — like, comment, share sesuai pattern akun normal. Tidak ada pattern bot yang TikTok bisa detect.</p>
                </div>
                <div class="why-card group" style="animation-delay: 200ms;">
                    <div class="why-icon">
                        <Heart class="w-6 h-6" strokeWidth="2.2" fill="currentColor" />
                    </div>
                    <h3 class="why-title">Cocok untuk Live Shopping</h3>
                    <p class="why-desc">TikTok Shop integration: viewers aktif lihat produk lebih lama, conversion naik 3-4x dibanding live sepi.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== FEATURES ====================== -->
    <section id="fitur" class="py-20 md:py-28 bg-soft relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    6 Keunggulan Layanan
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Kenapa layanan kami berbeda<br/>
                    <span class="text-accent">dari viewer bot biasa.</span>
                </h2>
            </div>

            <FeatureGrid items={features} client:visible />
        </div>
    </section>

    <!-- ====================== HOW IT WORKS ====================== -->
    <section class="py-20 md:py-28 bg-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(15,30,61,0.05) 1px, transparent 0); background-size: 32px 32px;"></div>

        <div class="container mx-auto px-6 relative">
            <div class="max-w-2xl mx-auto text-center mb-14 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-6 h-px bg-accent"></span>
                    Cara Kerja
                    <span class="w-6 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Dari order sampai FYP trending,<br/>
                    <span class="text-accent">kurang dari 30 menit.</span>
                </h2>
            </div>

            <StepGrid items={steps} client:visible />
        </div>
    </section>

    <!-- ====================== PRICING ====================== -->
    <section id="pricing" class="py-20 md:py-28 bg-gradient-to-br from-soft via-white to-beige relative overflow-hidden">
        <div class="abs-blob abs-blob-3"></div>
        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-accent">
                    <span class="w-8 h-px bg-accent"></span>
                    Paket & Harga
                    <span class="w-8 h-px bg-accent"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink leading-[1.1] tracking-tight mt-3">
                    Enam paket, dari pemanasan<br/>
                    <span class="text-accent">sampai launching akbar.</span>
                </h2>
                <p class="mt-4 text-muted max-w-xl mx-auto text-base leading-relaxed">
                    Semua paket sudah termasuk viewers riil (bukan bot), gradual entry, dan support via WhatsApp. Untuk paket mingguan/bulanan atau viewer 500+, chat dulu untuk harga khusus.
                </p>
            </div>

            <PricingCards tiers={tiers} pageSlug="View Live TikTok" highlightIndex={1} columns={3} client:only="svelte" />

            <div class="mt-10 max-w-2xl mx-auto reveal">
                <div class="bg-white rounded-2xl border border-gray-100 p-5 md:p-6 shadow-soft">
