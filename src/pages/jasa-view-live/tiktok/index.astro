const steps = [
    { num: '01', tag: 'HARI H', title: 'Kirim Detail Live TikTok', desc: 'Share username TikTok + tanggal/jam mulai live. Order dikonfirmasi max 30 menit setelah detail lengkap.' },
    { num: '02', tag: 'HARI H', title: 'Pembayaran & Persiapan', desc: 'Transfer via QRIS/e-wallet. Invoice langsung dikirim. DP 50% untuk paket besar tersedia.' },
    { num: '03', tag: 'LIVE', title: 'Viewers Join ke FYP', desc: 'Saat TikTok Live Anda mulai, viewers join gradual 5-15 menit. Algoritma FYP notice live Anda sebagai trending.' },
    { num: '04', tag: 'POST-LIVE', title: 'Evaluasi & Recurring', desc: 'Setelah live selesai, kami evaluasi performa FYP. Mau jadwal rutin 2-3x seminggu? Diskon 10-15% untuk paket berulang.' },
