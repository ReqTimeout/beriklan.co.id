---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.svelte';
import StickyCTA from '../../../components/StickyCTA.svelte';
import PricingCards from '../../../components/PricingCards.svelte';
import FaqAccordion from '../../../components/FaqAccordion.svelte';
import RelatedServices from '../../../components/RelatedServices.svelte';
import FeatureGrid from '../../../components/FeatureGrid.svelte';
import StepGrid from '../../../components/StepGrid.svelte';
import Footer from '../../../components/Footer.svelte';
import { MessageCircle, ArrowRight, Radio, Sparkles, Users, Shield, Clock, TrendingUp, Check, Smartphone, Heart, Music, Disc, PlayCircle, Eye, Volume2 } from 'lucide-svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20tertarik%20dengan%20jasa%20view%20live%20Tiktok.%20Mohon%20info%20paket%20dan%20harga.";

const tiers = [
    { name: 'Pemanasan', priceLabel: '12.000', duration: '20 viewers / 1 jam live', tagline: 'Cocok untuk warming up sebelum live utama biar algoritma notice Anda sejak awal.', features: ['20 viewers riil aktif', 'Bergabung gradual 5-15 menit', 'Multi-platform (TikTok + lain)', 'Cocok untuk live pendek atau tes', 'Tanpa risiko untuk akun TikTok'], priceNote: 'harga per sesi live', disclaimer: 'Viewers real account, no bot.' },
    { name: 'Starter', priceLabel: '25.000', duration: '50 viewers / 1 jam live', tagline: 'Untuk live rutin yang butuh boost awal agar FYP algorithm notice Anda.', features: ['50 viewers riil aktif', 'Bergabung gradual 5-15 menit', 'Multi-platform semua channel', 'Cocok untuk seller & streamer pemula', 'Real account, no flag dari TikTok'], priceNote: 'Rp 500/viewer/jam', disclaimer: 'Paling sering dipilih seller TikTok.', highlight: true },
    { name: 'Basic', priceLabel: '45.000', duration: '100 viewers / 1 jam live', tagline: 'Sweet spot untuk seller Twitch yang mau boost ranking & konversi.', features: ['100 viewers riil stay selama live', 'Bergabung gradual natural', 'Multi-platform semua channel', 'Cocok untuk seller Twitch', 'Boost distribusi FYP algorithm'], priceNote: 'Rp 450/viewer/jam', disclaimer: 'Cocok untuk live mingguan.' },
    { name: 'Pro', priceLabel: '80.000', duration: '200 viewers / 1 jam live', tagline: 'Untuk launching produk baru & live event yang butuh distribusi FYP luas.', features: ['200 viewers riil aktif', 'Bergabung gradual natural', 'Multi-platform semua channel', 'Cocok untuk launching & event', 'Boost organik distribusi FYP'], priceNote: 'Rp 400/viewer/jam', disclaimer: 'Repeat order diskon khusus.' },
    { name: 'Bisnis', priceLabel: '115.000', duration: '300 viewers / 1 jam live', tagline: 'Untuk brand dan toko yang live commerce TikTok rutin setiap hari.', features: ['300 viewers riil aktif', 'Bergabung gradual natural', 'Multi-platform semua channel', 'Cocok untuk live commerce harian', 'Support prioritas + account manager'], priceNote: 'Rp 383/viewer/jam', disclaimer: 'Cocok untuk paket mingguan.' },
    { name: 'Premium', priceLabel: '175.000', duration: '500 viewers / 1 jam live', tagline: 'Untuk launching event TikTok besar atau push viral dengan target viewers tinggi.', features: ['500 viewers riil aktif', 'Bergabung gradual natural', 'Multi-platform semua channel', 'Cocok untuk launching viral', 'Support 24/7 + flexible reschedule'], priceNote: 'Rp 350/viewer/jam', disclaimer: 'Untuk >500 viewers atau paket bulanan, custom price.' },
];

const features = [
    { iconName: 'Sparkles', title: 'Boost Rekomendasi', desc: 'Twitch merekomendasikan live berdasarkan concurrent viewers. Boost viewers = boost distribusi di direktori & rekomendasi.' },
    { iconName: 'Users', title: 'Real Account Twitch', desc: 'Viewers dari kami akun Twitch aktif — bukan bot. Stay, chat, dan bisa jadi follower.' },
    { iconName: 'TrendingUp', title: 'Masuk Gradual 5-15 Menit', desc: 'Viewers join gradual sejak menit pertama. Twitch algorithm notice live Anda sebagai live yang sedang trending.' },
    { iconName: 'Shield', title: 'Aman untuk Channel', desc: 'Viewers tidak spam chat. Tidak ada aktivitas dari akun channel. 1.200+ live tanpa masalah.' },
    { iconName: 'Smartphone', title: 'Masuk Twitch Live + Lainnya', desc: 'Order untuk Twitch Live, tapi viewers juga bisa stay di platform lain yang sedang live bersamaan. Multi-platform, satu order.' },
    { iconName: 'Clock', title: 'Start dalam 5 Menit', desc: 'Twitch Live Anda yang sudah jalan? Kami ikut real-time. Tidak perlu rekam ulang.' },
];

const steps = [
    { num: '01', tag: 'HARI H', title: 'Kirim Detail Live Twitch', desc: 'Share username Twitch + tanggal/jam mulai live. Order dikonfirmasi max 30 menit setelah detail lengkap.' },
    { num: '02', tag: 'HARI H', title: 'Pembayaran & Persiapan', desc: 'Transfer via QRIS/e-wallet. Invoice langsung dikirim. DP 50% untuk paket besar tersedia.' },
    { num: '03', tag: 'LIVE', title: 'Viewers Join ke FYP', desc: 'Saat Twitch Live Anda mulai, viewers join gradual 5-15 menit. Algoritma FYP notice live Anda sebagai trending.' },
    { num: '04', tag: 'POST-LIVE', title: 'Evaluasi & Recurring', desc: 'Setelah live selesai, kami evaluasi performa FYP. Mau jadwal rutin 2-3x seminggu? Diskon 10-15% untuk paket berulang.' },
];

const faqs = [
    { q: 'Apakah viewers-nya bot atau akun asli Twitch?', a: 'Akun asli Twitch, no automation. Mereka user aktif yang stay sesuai durasi live. Interaksi natural, no flag dari Twitch algorithm.' },
    { q: 'Apakah aman untuk akun Twitch saya?', a: 'Sangat aman. Viewers tidak like/comment spam yang bisa trigger shadow ban. Tidak ada aktivitas dari akun Anda. Sudah 1.200+ live Twitch tanpa satu pun kena masalah.' },
    { q: 'Berapa lama viewers muncul setelah live Twitch mulai?', a: '5-15 menit setelah live Anda mulai. Tidak tiba-tiba — gradual seperti live Twitch normal pada umumnya.' },
    { q: 'Apakah membantu algorithm Twitch?', a: 'Ya. Algorithm Twitch memprioritaskan live dengan viewers aktif. Boost viewers = boost distribusi sampai 5x lebih luas.' },
    { q: 'Bisa order untuk viewers lebih dari 500 atau paket mingguan/bulanan?', a: 'Bisa. Untuk 500+ viewers atau paket harian/mingguan dengan jadwal tetap, chat dulu via WA untuk harga terbaik. Recurring 2-3x seminggu bisa diskon 10-15%.' },
    { q: 'Apakah viewers stay selama durasi live Twitch?', a: 'Ya. Viewers dari kami stay sesuai durasi live yang Anda pesan. Kalau Anda live 1 jam, viewers stay 1 jam. Tidak ada yang tiba-tiba pergi di tengah live.' },
    { q: 'Bagaimana jika Twitch memberi flag setelah order?', a: 'Belum pernah terjadi. Viewers interaksi natural — like, comment, dan share sesuai pattern akun normal. Tidak ada pattern bot.' },
];

const relatedItems = [
    { icon: '🛍️', label: 'Jasa View Live Shopee', desc: 'Untuk seller Shopee Live yang fokus ke konversi produk.', href: '/jasa-view-live/shopee' },
    { icon: '🎬', label: 'Jasa View Live YouTube', desc: 'Untuk channel YouTube yang boost watch time & rekomendasi.', href: '/jasa-view-live/youtube' },
    { icon: '📡', label: 'Jasa View Live Multi-Platform', desc: 'Satu order, semua platform live.', href: '/jasa-view-live' },
];
---

<Layout title="Jasa View Live Twitch | Boost Viewers Concurrent Viewers — Beriklan" description="Boost viewers live streaming TikTok agar FYP algorithm notice live Anda. Real account, no bot, aman untuk akun TikTok. Mulai Rp 12.000 untuk 20 viewers." canonical="https://beriklan.co.id/jasa-view-live/twitch/">

    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-24 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#0e0e10] via-[#9146ff] to-[#6441a5]"></div>
        <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px); background-size: 48px 48px;"></div>

        <!-- Floating TikTok logo blur (background) -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] pointer-events-none opacity-20 blur-3xl" style="background: conic-gradient(from 0deg, #ff0050, #00f2ea, #ff0050); animation: spin 30s linear infinite; border-radius: 50%;"></div>

        <!-- Floating music notes animation -->
        <div class="absolute top-20 left-10 text-purple-500 opacity-20 music-note" style="animation-delay: 0s;">♪</div>
        <div class="absolute top-40 right-20 text-indigo-500 opacity-20 music-note" style="animation-delay: 0.5s;">♫</div>
        <div class="absolute bottom-40 left-1/4 text-purple-500 opacity-20 music-note" style="animation-delay: 1s;">♪</div>
        <div class="absolute top-1/2 right-1/4 text-indigo-500 opacity-20 music-note" style="animation-delay: 1.5s;">♬</div>

        <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
            <div class="space-y-7 text-center lg:text-left">
                <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white font-semibold rounded-full text-xs tracking-wider uppercase">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-pink-400"></span>
                    </span>
                    <span class="opacity-0 anim-fade-in text-purple-50">Jasa View Live Twitch · Boost Rekomendasi</span>
                </div>

                <h1 class="hero-h1 font-display font-extrabold text-4xl md:text-5xl lg:text-[2.6rem] xl:text-[2.9rem] text-white leading-[1.05] tracking-tight">
                    <span class="anim-fade-up">Live Twitch Sepi,</span><br/>
                    <span class="anim-fade-up text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-indigo-500" style="animation-delay: 80ms;">Discover Tidak Rekomendasi.</span><br/>
                    <span class="anim-fade-up" style="animation-delay: 160ms;">— Butuh Viewers Aktif.</span>
                </h1>

                <p class="hero-sub text-base md:text-lg text-white/80 leading-relaxed max-w-xl mx-auto lg:mx-0 anim-fade-up" style="animation-delay: 240ms;">
                    TikTok For You Page memprioritaskan live dengan viewers aktif. 100+ viewers = 5x lebih besar jangkauan FYP. Viewer riil dari kami join gradual sejak menit pertama — bikin algoritma TikTok notice live Anda, tanpa flag, tanpa bot, tanpa risiko shadow ban.
                </p>

                <div class="hero-ctas flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2 anim-fade-up" style="animation-delay: 320ms;">
                    <a href={waLink} target="_blank" rel="noopener" class="group relative inline-flex items-center justify-center gap-2 bg-white text-black px-7 py-4 rounded-full font-bold shadow-lg hover:shadow-pop overflow-hidden btn-shine">
                        <span class="relative z-10 flex items-center gap-2">
                            Order Viewers TikTok
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 group-hover:rotate-12 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                    </a>
                    <a href="#pricing" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full font-bold text-white border border-white/30 bg-white/5 backdrop-blur-sm hover:bg-white/15 transition-all">
                        Lihat Paket & Harga
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </a>
                </div>

                <div class="hero-trust pt-6 border-t border-white/20 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-xs md:text-sm reveal" style="transition-delay: 200ms;">
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-white/80"><strong class="text-white">Mulai Rp 12.000</strong> untuk 20 viewers</span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-white/80">Real account, <strong class="text-white">no bot</strong></span></div>
                    <div class="flex items-center gap-2 trust-item"><span class="check-icon"></span><span class="text-white/80">Boost viewers & followers</span></div>
                </div>
            </div>

            <!-- TikTok live mockup with real TikTok logo + platform-specific animations -->
            <div class="relative flex justify-center lg:justify-end anim-fade-up" style="animation-delay: 400ms;">
                <div class="relative w-full max-w-md mx-auto">
                    <!-- Floating TikTok logo big behind -->
                    <div class="absolute -top-12 -right-12 w-40 h-40 opacity-30 blur-2xl pointer-events-none" style="background: linear-gradient(135deg, #ff0050, #00f2ea); border-radius: 50%; animation: pulse 3s ease-in-out infinite;"></div>

                    <!-- Music equalizer bars (TikTok style) -->
                    <div class="absolute -left-8 top-1/3 flex flex-col gap-2 opacity-50">
                        <div class="eq-bar w-1.5 bg-pink-400 rounded-full" style="height: 24px; animation: eq-bounce 1.2s ease-in-out infinite;"></div>
                        <div class="eq-bar w-1.5 bg-pink-400 rounded-full" style="height: 36px; animation: eq-bounce 1.2s ease-in-out infinite 0.1s;"></div>
                        <div class="eq-bar w-1.5 bg-indigo-600 rounded-full" style="height: 48px; animation: eq-bounce 1.2s ease-in-out infinite 0.2s;"></div>
                        <div class="eq-bar w-1.5 bg-pink-400 rounded-full" style="height: 32px; animation: eq-bounce 1.2s ease-in-out infinite 0.3s;"></div>
                        <div class="eq-bar w-1.5 bg-indigo-600 rounded-full" style="height: 40px; animation: eq-bounce 1.2s ease-in-out infinite 0.4s;"></div>
                    </div>
                    <div class="absolute -right-8 top-1/3 flex flex-col gap-2 opacity-50">
                        <div class="eq-bar w-1.5 bg-indigo-600 rounded-full" style="height: 40px; animation: eq-bounce 1.2s ease-in-out infinite 0.1s;"></div>
                        <div class="eq-bar w-1.5 bg-pink-400 rounded-full" style="height: 56px; animation: eq-bounce 1.2s ease-in-out infinite 0.2s;"></div>
                        <div class="eq-bar w-1.5 bg-indigo-600 rounded-full" style="height: 32px; animation: eq-bounce 1.2s ease-in-out infinite 0.3s;"></div>
                        <div class="eq-bar w-1.5 bg-pink-400 rounded-full" style="height: 44px; animation: eq-bounce 1.2s ease-in-out infinite 0.4s;"></div>
                        <div class="eq-bar w-1.5 bg-indigo-600 rounded-full" style="height: 28px; animation: eq-bounce 1.2s ease-in-out infinite 0.5s;"></div>
                    </div>

                    <!-- Phone frame with TikTok branding -->
                    <div class="rounded-3xl overflow-hidden bg-gradient-to-br from-black to-[#1a0a2e] border-4 border-white shadow-2xl aspect-[9/16] max-h-[560px] relative">
                        <!-- TikTok-style top bar -->
                        <div class="absolute top-0 left-0 right-0 p-3 flex items-center gap-2 bg-gradient-to-b from-black/95 to-transparent z-10">
                            <div class="w-8 h-8 rounded-full bg-black border-2 border-pink-500 flex items-center justify-center overflow-hidden twitch-logo-spin">
                                <img src="/tech/platforms/twitch.svg" alt="TikTok" class="w-5 h-5" style="filter: brightness(0) invert(1);" />
                            </div>
                            <div class="flex-1">
                                <p class="text-white text-xs font-bold">channel_twitch</p>
                                <p class="text-white/70 text-[10px] flex items-center gap-1">
                                    <span class="relative flex h-1.5 w-1.5">
                                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-400 opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-pink-400"></span>
                                    </span>
                                    LIVE · For You
                                </p>
                            </div>
                            <div class="px-2 py-1 bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-[10px] font-bold rounded-full uppercase tracking-wider twitch-pill-pulse">TikTok</div>
                        </div>
                        <!-- Viewer count -->
                        <div class="absolute top-12 right-3 z-10 px-2 py-1 bg-black/60 backdrop-blur-md rounded-full text-white text-[10px] font-bold flex items-center gap-1 border border-white/20">
                            <Users class="w-3 h-3 text-indigo-500" />
                            <span>500 viewers</span>
                        </div>
                        <!-- LIVE badge -->
                        <div class="absolute top-12 left-3 z-10">
                            <div class="flex items-center gap-1.5 bg-purple-600 text-white text-[10px] font-bold px-2 py-1 rounded-full twitch-live-blink">
                                <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
                                LIVE
                            </div>
                        </div>
                        <!-- Chat overlay -->
                        <div class="absolute bottom-12 left-3 right-3 space-y-1.5 z-10 max-h-32 overflow-hidden">
                            <div class="flex items-start gap-1.5"><span class="px-1.5 py-0.5 bg-purple-600/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user1</span><span class="text-white text-[11px] drop-shadow">stream mantap bro!</span></div>
                            <div class="flex items-start gap-1.5"><span class="px-1.5 py-0.5 bg-indigo-600/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user2</span><span class="text-white text-[11px] drop-shadow">Kek pov 7 bro</span></div>
                            <div class="flex items-start gap-1.5"><span class="px-1.5 py-0.5 bg-purple-600/80 backdrop-blur-sm text-white text-[10px] font-bold rounded">user3</span><span class="text-white text-[11px] drop-shadow">folowed!</span></div>
                        </div>
                        <!-- Product overlay -->
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <div class="w-32 h-32 rounded-2xl bg-gradient-to-br from-pink-500/40 to-cyan-400/40 backdrop-blur-sm border-2 border-white/40 flex items-center justify-center twitch-product-bounce">
                                <div class="text-center">
                                    <p class="text-white text-[10px] font-bold uppercase tracking-wider">Shopping</p>
                                    <p class="text-white text-base font-bold">Twitch Live</p>
                                    <p class="text-purple-500 text-sm font-extrabold">Rp 99K</p>
                                </div>
                            </div>
                        </div>
                        <!-- Cart button -->
                        <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/95 to-transparent">
                            <div class="bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-center py-2 rounded-full text-xs font-bold flex items-center justify-center gap-1 twitch-cta-glow">
                                <Heart class="w-3 h-3" fill="currentColor" />
                                FOLLOW
                            </div>
                        </div>
                    </div>

                    <!-- Big TikTok logo overlay (rotating) -->
                    <div class="absolute -bottom-12 -right-12 w-32 h-32 opacity-80 pointer-events-none twitch-logo-orbit">
                        <img src="/tech/platforms/twitch.svg" alt="TikTok" class="w-full h-full" style="filter: brightness(0) invert(1) drop-shadow(0 0 30px #9146ff99) drop-shadow(0 0 30px #6441a599);" />
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- ====================== TRUST BAR ====================== -->
    <section class="py-7 bg-black/40 border-y border-white/5 relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
                <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.18em] text-white/40">Optimal untuk TikTok</p>
                <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-white/70 text-sm font-semibold">
                    <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-pink-400"></span>Concurrent Viewers</span>
                    <span class="text-white/30">·</span>
                    <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-indigo-600"></span>Live Shopping</span>
                    <span class="text-white/30">·</span>
                    <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-pink-400"></span>Twitch</span>
                    <span class="text-white/30">·</span>
                    <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-indigo-600"></span>Discover</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ====================== WHY TIKTOK ====================== -->
    <section class="py-20 md:py-28 bg-gradient-to-br from-[#0e0e10] via-[#9146ff] to-[#6441a5] text-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-20 pointer-events-none" style="background: radial-gradient(circle at 30% 30%, #9146ff26 0%, transparent 50%), radial-gradient(circle at 70% 70%, #6441a526 0%, transparent 50%);"></div>

        <div class="container mx-auto px-6 relative">
            <div class="text-center max-w-2xl mx-auto mb-12 reveal">
                <p class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.2em] text-purple-500">
                    <span class="w-8 h-px bg-gradient-to-r from-transparent to-pink-400"></span>
                    Kenapa View Live Twitch
                    <span class="w-8 h-px bg-gradient-to-l from-transparent to-cyan-400"></span>
                </p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-white leading-[1.1] tracking-tight mt-3">
                    Apa algoritma Twitch satu hal:<br/>
                    <span class="bg-gradient-to-r from-purple-500 to-indigo-500 bg-clip-text text-transparent">banyak viewers = muncul di direktori.</span>
                </h2>
                <p class="mt-4 text-white/70 max-w-xl mx-auto text-base leading-relaxed">
                    Twitch merekomendasikan live berdasarkan concurrent viewers. Live dengan 100+ viewers muncul 4x lebih sering di direktori Twitch dibanding live dengan 20 viewers.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="twitch-why-card group">
                    <div class="twitch-why-icon">
                        <Sparkles class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="twitch-why-title">Boost Rekomendasi</h3>
                    <p class="twitch-why-desc">Twitch merekomendasikan live dengan viewers aktif. Boost viewers = boost distribusi di direktori Twitch.</p>
                </div>
                <div class="twitch-why-card group" style="animation-delay: 100ms;">
                    <div class="twitch-why-icon">
                        <Shield class="w-6 h-6" strokeWidth="2.2" />
                    </div>
                    <h3 class="twitch-why-title">Aman untuk Channel</h3>
                    <p class="twitch-why-desc">Viewers dari kami akun Twitch aktif. Tidak spam chat. Tidak ada aktivitas dari akun channel. 1.200+ live tanpa masalah.</p>
                </div>
                <div class="twitch-why-card group" style="animation-delay: 200ms;">
                    <div class="twitch-why-icon">
                        <Heart class="w-6 h-6" strokeWidth="2.2" fill="currentColor" />
                    </div>
                    <h3 class="twitch-why-title">Cocok untuk Semua Genre</h3>
                    <p class="twitch-why-desc">Cocok untuk gaming, just chatting, music, art, atau IRL stream. Viewer real account stay & engage.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="fitur" class="py-20 md:py-28 bg-gradient-to-br from-soft via-white to-beige relative overflow-hidden">
