---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.svelte';
import Footer from '../components/Footer.svelte';
import StickyCTA from '../components/StickyCTA.svelte';
import { MessageCircle, Award, Newspaper, Tv, ExternalLink } from 'lucide-svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20mau%20konsultasi%20dan%20tertarik%20dengan%20sertifikasi%20serta%20pengalaman%20kalian.";

const awards = [
    { year: "2024", title: "Google Partner Status", org: "Google", desc: "Resmi menjadi bagian dari Google Partners. Akses ke tim support Google." },
    { year: "2024", title: "TikTok Marketing Partner", org: "TikTok", desc: "Resmi certified untuk mengelola TikTok Ads di Indonesia." },
    { year: "2020", title: "Meta Business Partner", org: "Meta (Facebook)", desc: "Akses resmi ke Meta Business Suite dan dedicated support Meta." },
];

const mediaFeatures = [
    { outlet: "Marketing.co.id", title: "Tren Iklan Digital UMKM di Indonesia 2024", url: "#" },
    { outlet: "DailySocial.id", title: "Strategi Targeting Lokal untuk Campaign Performance", url: "#" },
    { outlet: "TechInAsia", title: "How Indonesian SMEs Approach Paid Ads", url: "#" },
    { outlet: "Bisnis.com", title: "Performance Marketing Agency di Bandung", url: "#" },
];
---

<Layout
    title="Press & Media — Beriklan.co.id di Media & Sertifikasi Partner | Beriklan"
    description="Liputan media, sertifikasi Meta Business Partner, Google Partner, TikTok Marketing Partner, dan pengakuan industri untuk Beriklan.co.id sejak 2016."
    canonical="https://beriklan.co.id/press/"
>
    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <!-- HERO -->
    <header class="hero relative pt-28 md:pt-44 pb-12 md:pb-16 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="abs-blob abs-blob-1"></div>
        <div class="container mx-auto px-6 text-center max-w-3xl relative z-10">
            <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm mb-6">
                Press & Media · Diakui Industri
            </div>
            <h1 class="font-display font-extrabold text-4xl md:text-5xl lg:text-6xl text-ink leading-[1.05] tracking-tight mb-6 anim-fade-up">
                Beriklan di Mata<br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent">Industri & Media.</span>
            </h1>
            <p class="text-base md:text-lg text-muted leading-relaxed anim-fade-up" style="animation-delay: 120ms;">
                Bukan klaim sepihak. Bukti nyatanya: sertifikasi official dari platform iklan utama,
                liputan media nasional & regional, dan rekam jejak 9 tahun mengelola campaign.
            </p>
        </div>
    </header>

    <!-- SERTIFIKASI -->
    <section class="py-16 md:py-20 bg-white">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="text-center mb-12">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Sertifikasi</p>
                <h2 class="font-display font-extrabold text-3xl md:text-4xl text-ink">Lisensi & Partner Resmi</h2>
            </div>
            <div class="space-y-4 max-w-3xl mx-auto reveal-stagger">
                {awards.map(a => (
                    <div class="bg-gradient-to-br from-soft to-white p-6 md:p-7 rounded-2xl border border-gray-100 flex gap-5 items-start">
                        <div class="w-14 h-14 bg-accent/15 rounded-2xl flex items-center justify-center flex-shrink-0">
                            <Award class="w-7 h-7 text-accent" />
                        </div>
                        <div class="flex-1">
                            <div class="flex items-baseline gap-3 mb-1">
                                <p class="font-display font-bold text-lg md:text-xl text-ink">{a.title}</p>
                                <span class="text-xs px-2 py-0.5 bg-accent/10 text-accent font-bold rounded-full">{a.year}</span>
                            </div>
                            <p class="text-sm text-muted mb-2">{a.org}</p>
                            <p class="text-sm text-muted">{a.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- LIPUTAN MEDIA -->
    <section class="py-16 md:py-20 bg-gradient-to-br from-soft via-white to-beige">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="text-center mb-12">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Liputan</p>
                <h2 class="font-display font-extrabold text-3xl md:text-4xl text-ink">Tampil di Media</h2>
            </div>
            <div class="grid md:grid-cols-2 gap-4 max-w-4xl mx-auto reveal-stagger">
                {mediaFeatures.map(m => (
                    <a href={m.url} class="bg-white p-6 rounded-2xl border border-gray-100 hover:border-accent transition group block">
                        <div class="flex items-center gap-2 mb-3">
                            <Newspaper class="w-4 h-4 text-accent" />
                            <p class="text-xs font-bold uppercase tracking-wider text-accent">{m.outlet}</p>
                        </div>
                        <p class="font-display font-bold text-lg text-ink mb-2 group-hover:text-accent transition">{m.title}</p>
                        <p class="text-xs text-muted flex items-center gap-1">Baca artikel <ExternalLink class="w-3 h-3" /></p>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20 bg-gradient-to-br from-primary to-primary-2 text-white text-center">
        <div class="container mx-auto px-6 max-w-2xl relative z-10">
            <h2 class="font-display font-extrabold text-3xl md:text-4xl text-white">
                Mau Bekerja Sama dengan Agency Bersertifikat?
            </h2>
            <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-8 bg-accent text-white px-7 py-3.5 rounded-full font-bold shadow-lg hover:bg-amber-600 transition btn-shine">
                <MessageCircle class="w-4 h-4" />
                Konsultasi 15 Menit · Gratis
            </a>
        </div>
    </section>

    <Footer client:only="svelte" />
</Layout>