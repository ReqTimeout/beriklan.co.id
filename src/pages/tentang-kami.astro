---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.svelte';
import Footer from '../components/Footer.svelte';
import StickyCTA from '../components/StickyCTA.svelte';
import { MapPin, Phone, Mail, MessageCircle, Clock, Award, Users, Calendar, Sparkles } from 'lucide-svelte';

const waLink = "https://wa.me/62811919328?text=Halo%20Beriklan%2C%20saya%20ingin%20berkenalan%20dan%20tahu%20lebih%20lanjut%20tentang%20tim%20Beriklan.";
const phoneLink = "tel:+62811919328";
const mailLink = "mailto:info@beriklan.co.id?subject=Konsultasi%20Digital%20Marketing";

const schemaOrg = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Beriklan Digital Agency",
    "url": "https://beriklan.co.id/",
    "logo": "https://beriklan.co.id/logoweb.webp",
    "foundingDate": "2016-01-01",
    "founders": [
        { "@type": "Person", "name": "Tim Beriklan" }
    ],
    "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+62-81-1919-328",
        "contactType": "customer service",
        "areaServed": "ID",
        "availableLanguage": ["Indonesian", "English"]
    },
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "Jl. Arcamanik Endah No.76",
        "addressLocality": "Bandung",
        "postalCode": "40195",
        "addressCountry": "ID"
    },
    "sameAs": [
        "https://www.facebook.com/beriklan",
        "https://www.instagram.com/beriklan.co.id",
        "https://www.linkedin.com/company/beriklan"
    ],
    "award": ["Meta Business Partner", "Google Partner", "TikTok Marketing Partner"]
};

const schemaPerson = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Tim Beriklan",
    "jobTitle": "Performance Marketing Lead",
    "worksFor": { "@type": "Organization", "name": "Beriklan Digital Agency" },
    "url": "https://beriklan.co.id/tentang-kami/"
};
---

<Layout
    title="Tentang Beriklan.co.id — Tim Performance Marketing Sejak 2016 | Beriklan"
    description="Beriklan Digital Agency berdiri sejak 2016, berbasis Bandung, mengelola campaign iklan Meta, Google, TikTok, YouTube untuk UMKM & bisnis menengah Indonesia. Tim bersertifikasi Meta & Google Partner."
    canonical="https://beriklan.co.id/tentang-kami/"
    schema="organization"
>
    <Navbar client:only="svelte" />
    <StickyCTA client:only="svelte" />

    <!-- HERO -->
    <header class="hero relative pt-28 md:pt-44 pb-16 md:pb-24 overflow-hidden bg-gradient-to-br from-white via-soft to-beige">
        <div class="absolute inset-0 opacity-[0.4] pointer-events-none hero-grid"></div>
        <div class="abs-blob abs-blob-1"></div>
        <div class="abs-blob abs-blob-2"></div>
        <div class="container mx-auto px-6 text-center max-w-3xl relative z-10">
            <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-ink font-semibold rounded-full text-xs tracking-wider uppercase shadow-sm mb-6">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
                </span>
                Tentang Kami · Sejak 2016 · Bandung
            </div>
            <h1 class="font-display font-extrabold text-4xl md:text-5xl lg:text-6xl text-ink leading-[1.05] tracking-tight mb-6 anim-fade-up">
                Beriklan, Bukan Sekadar<br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-2 to-accent">Pasang Iklan — Tapi Partner</span><br/>
                Strategi Performa.
            </h1>
            <p class="text-base md:text-lg text-muted leading-relaxed mb-8 anim-fade-up" style="animation-delay: 120ms;">
                Sejak 2016 kami mendampingi UMKM & bisnis menengah Indonesia mengelola lebih dari
                ratusan campaign iklan digital — Meta, Google, TikTok, YouTube. Bukan agensi yang
                menyembunyikan akun. Kami berikan akses penuh, dashboard real-time, dan laporan
                yang bisa dipertanggungjawabkan.
            </p>
        </div>
    </header>

    <!-- QUICK STATS -->
    <section class="py-12 md:py-16 bg-white">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-5 max-w-5xl mx-auto reveal-stagger">
                <div class="text-center p-6 bg-gradient-to-br from-soft to-white rounded-2xl border border-gray-100">
                    <p class="font-display font-extrabold text-3xl md:text-4xl text-primary mb-1">9</p>
                    <p class="text-xs text-muted uppercase tracking-wider font-bold">Tahun Pengalaman</p>
                </div>
                <div class="text-center p-6 bg-gradient-to-br from-soft to-white rounded-2xl border border-gray-100">
                    <p class="font-display font-extrabold text-3xl md:text-4xl text-primary mb-1">100+</p>
                    <p class="text-xs text-muted uppercase tracking-wider font-bold">Campaign Dikelola</p>
                </div>
                <div class="text-center p-6 bg-gradient-to-br from-soft to-white rounded-2xl border border-gray-100">
                    <p class="font-display font-extrabold text-3xl md:text-4xl text-primary mb-1">3</p>
                    <p class="text-xs text-muted uppercase tracking-wider font-bold">Sertifikasi Partner</p>
                </div>
                <div class="text-center p-6 bg-gradient-to-br from-soft to-white rounded-2xl border border-gray-100">
                    <p class="font-display font-extrabold text-3xl md:text-4xl text-primary mb-1">1 jam</p>
                    <p class="text-xs text-muted uppercase tracking-wider font-bold">Respon WhatsApp</p>
                </div>
            </div>
        </div>
    </section>

    <!-- STORY / MISI / VISI -->
    <section class="py-20 md:py-28 bg-gradient-to-br from-soft via-white to-beige">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="text-center mb-16">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Cerita Beriklan</p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink">
                    Berawal dari Audit, Berakhir Jadi Mitra
                </h2>
            </div>
            <div class="grid md:grid-cols-2 gap-12 reveal-stagger">
                <div class="bg-white rounded-2xl p-8 shadow-soft border border-gray-100">
                    <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Misi</p>
                    <h3 class="font-display font-bold text-xl text-ink mb-4">Membawa Iklan Digital yang Terukur ke UMKM Indonesia</h3>
                    <p class="text-muted leading-relaxed">
                        Mayoritas UMKM Indonesia gagal di iklan digital karena tiga hal: targeting melebar,
                        creative tidak selaras dengan audience, atau landing page tidak konversi. Beriklan
                        berdiri untuk mendiagnosa ketiga masalah itu dulu, baru merumuskan strategi yang
                        terukur untuk bisnis Anda.
                    </p>
                </div>
                <div class="bg-white rounded-2xl p-8 shadow-soft border border-gray-100">
                    <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Visi</p>
                    <h3 class="font-display font-bold text-xl text-ink mb-4">Mitra Performa Senior, Bukan Vendor Eksekusi</h3>
                    <p class="text-muted leading-relaxed">
                        Kami memposisikan diri sebagai "Senior Performance Marketing Partner" — bukan
                        vendor yang sekadar pasang iklan. Setiap klien mendapat pendampingan strategis,
                        dashboard real-time, dan laporan mingguan yang actionable. Anda tahu persis
                        ke mana setiap rupiah iklan dibelanjakan.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- TIMELINE / MILESTONES -->
    <section class="py-20 md:py-28 bg-white">
        <div class="container mx-auto px-6 max-w-4xl">
            <div class="text-center mb-16">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Perjalanan</p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-ink">
                    9 Tahun Mengelola Campaign
                </h2>
            </div>
            <ol class="timeline-list">
                <li class="timeline-item">
                    <span class="timeline-year">2016</span>
                    <p class="timeline-text">Mulai mengelola campaign Facebook Ads untuk UMKM Bandung.</p>
                </li>
                <li class="timeline-item">
                    <span class="timeline-year">2018</span>
                    <p class="timeline-text">Ekspansi ke Instagram Ads dan Google Ads (Search & Display).</p>
                </li>
                <li class="timeline-item">
                    <span class="timeline-year">2020</span>
                    <p class="timeline-text">Mendapat Meta Business Partner status. Beralih ke full-service agency.</p>
                </li>
                <li class="timeline-item">
                    <span class="timeline-year">2022</span>
                    <p class="timeline-text">Tambah layanan YouTube Ads & organic Instagram/TikTok management.</p>
                </li>
                <li class="timeline-item">
                    <span class="timeline-year">2024</span>
                    <p class="timeline-text">Google Partner + TikTok Marketing Partner.</p>
                </li>
                <li class="timeline-item">
                    <span class="timeline-year">2026</span>
                    <p class="timeline-text">Rebrand menjadi Beriklan.co.id. Migrasi ke platform Otomatis.</p>
                </li>
            </ol>
        </div>
    </section>

    <!-- SERTIFIKASI / CREDENTIALS -->
    <section class="py-20 md:py-28 bg-gradient-to-br from-primary to-primary-2 text-white">
        <div class="container mx-auto px-6 max-w-5xl">
            <div class="text-center mb-12">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Kredensial</p>
                <h2 class="font-display font-extrabold text-3xl md:text-5xl text-white">
                    Tersertifikasi, Berlisensi Resmi
                </h2>
                <p class="text-base text-white/70 mt-4 max-w-2xl mx-auto">
                    Status partner official dari platform iklan utama — bukan sertifikat abal-abal
                    yang bisa Anda cek langsung di direktori partner.
                </p>
            </div>
            <div class="grid md:grid-cols-3 gap-5 reveal-stagger">
                <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
                    <Award class="w-8 h-8 text-accent mb-3" />
                    <p class="font-display font-bold text-lg text-white">Meta Business Partner</p>
                    <p class="text-sm text-white/70 mt-2">Verifikasi di direktori partner Meta.</p>
                </div>
                <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
                    <Award class="w-8 h-8 text-accent mb-3" />
                    <p class="font-display font-bold text-lg text-white">Google Partner</p>
                    <p class="text-sm text-white/70 mt-2">Search, Display, YouTube Ads certified.</p>
                </div>
                <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
                    <Award class="w-8 h-8 text-accent mb-3" />
                    <p class="font-display font-bold text-lg text-white">TikTok Marketing Partner</p>
                    <p class="text-sm text-white/70 mt-2">Akses resmi TikTok Ads Manager.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20 bg-gradient-to-br from-primary to-primary-2 text-white text-center">
        <div class="container mx-auto px-6 max-w-2xl relative z-10">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3">Diskusi 15 Menit · Tanpa Biaya</p>
            <h2 class="font-display font-extrabold text-3xl md:text-4xl text-white">
                Mau Tahu Apakah Beriklan<br/>Cocok untuk Bisnis Anda?
            </h2>
            <p class="text-base text-white/80 mt-4">
                Konsultasi awal 15 menit via WhatsApp — tim kami online · respon dalam 1 jam pada jam kerja.
            </p>
            <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-8 bg-accent text-white px-7 py-3.5 rounded-full font-bold shadow-lg hover:bg-amber-600 transition btn-shine">
                <MessageCircle class="w-4 h-4" />
                Chat WhatsApp Tim Beriklan
            </a>
        </div>
    </section>

    <Footer client:only="svelte" />
</Layout>

<style>
    .timeline-list {
        position: relative;
        padding-left: 80px;
    }
    .timeline-list::before {
        content: '';
        position: absolute;
        left: 60px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(to bottom, #f59e0b, #f59e0b33);
    }
    .timeline-item {
        position: relative;
        padding: 1rem 0;
    }
    .timeline-item::before {
        content: '';
        position: absolute;
        left: -28px;
        top: 1.5rem;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #f59e0b;
        box-shadow: 0 0 0 4px white;
    }
    .timeline-year {
        position: absolute;
        left: -80px;
        top: 0.9rem;
        font-weight: 800;
        font-size: 0.95rem;
        color: #f59e0b;
        width: 50px;
        text-align: right;
    }
    .timeline-text {
        color: #4b5563;
        font-size: 0.95rem;
        line-height: 1.6;
    }
    @media (max-width: 768px) {
        .timeline-list { padding-left: 60px; }
        .timeline-list::before { left: 30px; }
        .timeline-item::before { left: -32px; }
        .timeline-year { left: -60px; }
    }
</style>

<script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
<script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} />