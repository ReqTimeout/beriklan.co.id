{
  "name": "beriklanweb",
  "main": "src/worker-entry.js",
  "compatibility_date": "2026-01-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "beriklan-seo",
      "database_id": "0e71d6e3-231f-40a1-ac6b-6defc3976efd"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "ADMIN_TOKEN": "beriklan-admin-2026"
  },
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "triggers": [
    { "cron": "0 * * * *" },
    { "cron": "0 */6 * * *" },
    { "cron": "30 */6 * * *" }
  ]
}
